---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Creation Site WordPress Sur Mesure a Perpignan — Stephane Duma"
  description="Creation de sites WordPress professionnels a Perpignan. Themes sur mesure, WooCommerce, performance et SEO. Pas de page builders, du vrai code. +10 ans d'experience."
  canonical="https://stephduma.dev/creation-site-wordpress"
  keywords="creation site wordpress perpignan, developpeur wordpress freelance, theme wordpress sur mesure, woocommerce perpignan, site internet perpignan"
>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center px-6 md:px-12 overflow-hidden pt-24" style="background: radial-gradient(ellipse 70% 70% at 60% 40%, #f5f0eb 0%, #ede8e3 60%, #e8e3de 100%);">

    <!-- Decorative WP-inspired shapes -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <!-- Large ring -->
      <div class="absolute top-[8%] right-[5%] w-[400px] h-[400px] md:w-[600px] md:h-[600px] rounded-full border border-[#1A1A1A]/[0.04]" style="animation: spin-slow 60s linear infinite;"></div>
      <div class="absolute top-[12%] right-[8%] w-[320px] h-[320px] md:w-[480px] md:h-[480px] rounded-full border border-[#1A1A1A]/[0.03]" style="animation: spin-slow 45s linear infinite reverse;"></div>
      <!-- Scattered dots -->
      <div class="absolute top-[25%] right-[20%] w-2 h-2 rounded-full bg-[#1A1A1A]/[0.06]"></div>
      <div class="absolute top-[35%] right-[30%] w-1.5 h-1.5 rounded-full bg-[#1A1A1A]/[0.05]"></div>
      <div class="absolute bottom-[30%] left-[15%] w-2.5 h-2.5 rounded-full bg-[#1A1A1A]/[0.04]"></div>
    </div>

    <div class="max-w-6xl mx-auto w-full relative z-10">
      <div class="max-w-4xl">
        <!-- Breadcrumb -->
        <div class="reveal flex items-center gap-2 text-xs text-[#A0A0A0] mb-8" style="font-family:'DM Sans',sans-serif; letter-spacing:1px;">
          <a href="/" class="hover:text-[#1A1A1A] transition-colors">Accueil</a>
          <span>/</span>
          <a href="/#services" class="hover:text-[#1A1A1A] transition-colors">Services</a>
          <span>/</span>
          <span class="text-[#1A1A1A]">WordPress</span>
        </div>

        <div class="reveal">
          <span class="section-label mb-8 inline-block" style="border-color:#D2C8BC; color:#8B7D6B;">WordPress</span>
        </div>

        <h1 class="reveal text-[#1A1A1A] leading-[0.92] mb-8" style="font-family:'Playfair Display',serif; font-size:clamp(2.8rem,8vw,7rem); font-weight:900; letter-spacing:-2px;">
          Sites WordPress<br/>
          <span class="relative inline-block">
            sur mesure
            <span class="absolute -bottom-2 left-0 w-full h-[3px] rounded-full" style="background: linear-gradient(90deg, #1A1A1A/10, transparent);"></span>
          </span>
        </h1>

        <p class="reveal text-[#6B6B6B] text-lg md:text-xl leading-relaxed max-w-2xl mb-12">
          Pas de templates generiques. Pas de page builders. Des themes WordPress codes a la main, performants, maintenables et qui vous ressemblent vraiment.
        </p>

        <div class="reveal flex flex-wrap items-center gap-4">
          <a href="/#contact" class="inline-flex items-center gap-3 px-7 py-3.5 bg-[#1A1A1A] text-white rounded-full text-sm font-medium hover:bg-[#333] transition-all duration-300 hover:gap-5 group">
            Demander un devis
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="group-hover:rotate-45 transition-transform duration-300"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
          <a href="#approche" class="inline-flex items-center gap-2 px-7 py-3.5 border border-[#D2C8BC] rounded-full text-sm text-[#6B6B6B] hover:border-[#1A1A1A] hover:text-[#1A1A1A] transition-all duration-300">
            Mon approche
          </a>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="reveal mt-20 pt-8 border-t border-[#D8D8D8]">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div>
            <div class="serif-italic text-4xl md:text-5xl text-[#1A1A1A]">150+</div>
            <div class="text-sm text-[#6B6B6B] mt-2">Sites WordPress livres</div>
          </div>
          <div>
            <div class="serif-italic text-4xl md:text-5xl text-[#1A1A1A]">8 ans</div>
            <div class="text-sm text-[#6B6B6B] mt-2">D'expertise WordPress</div>
          </div>
          <div>
            <div class="serif-italic text-4xl md:text-5xl text-[#1A1A1A]">0</div>
            <div class="text-sm text-[#6B6B6B] mt-2">Page builder utilise</div>
          </div>
          <div>
            <div class="serif-italic text-4xl md:text-5xl text-[#1A1A1A]">A+</div>
            <div class="text-sm text-[#6B6B6B] mt-2">Grade securite</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PHILOSOPHY — what makes me different -->
  <section id="approche" class="py-24 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Philosophie</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]" style="line-height:1.1;">
          WordPress, mais autrement
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div class="reveal">
          <p class="text-[#6B6B6B] leading-relaxed text-base mb-8">
            La plupart des sites WordPress sont construits avec des page builders (Elementor, Divi) qui alourdissent le code, ralentissent le chargement et creent une dependance technique. Mon approche est radicalement differente.
          </p>
          <p class="text-[#6B6B6B] leading-relaxed text-base">
            Je code chaque theme from scratch : PHP, HTML, CSS, JavaScript. Le resultat est un site leger, rapide, securise et parfaitement adapte a vos besoins. Pas de superflu, que de l'essentiel.
          </p>
        </div>

        <div class="space-y-4">
          <!-- Comparison cards -->
          <div class="reveal rounded-2xl border border-[#E5E5E5] p-6 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full bg-[#DC2626]/30"></div>
            <div class="pl-4">
              <div class="text-xs text-[#DC2626] uppercase tracking-wider font-medium mb-2">WordPress classique</div>
              <ul class="text-sm text-[#6B6B6B] space-y-1.5">
                <li class="flex items-start gap-2"><span class="text-[#DC2626] mt-0.5">&#10005;</span> 30+ plugins pour tout</li>
                <li class="flex items-start gap-2"><span class="text-[#DC2626] mt-0.5">&#10005;</span> Page builder lourd (+2MB)</li>
                <li class="flex items-start gap-2"><span class="text-[#DC2626] mt-0.5">&#10005;</span> Mises a jour qui cassent tout</li>
                <li class="flex items-start gap-2"><span class="text-[#DC2626] mt-0.5">&#10005;</span> Score Lighthouse &lt; 50</li>
              </ul>
            </div>
          </div>

          <div class="reveal rounded-2xl bg-[#141414] p-6 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full bg-[#22C55E]"></div>
            <div class="pl-4">
              <div class="text-xs text-[#22C55E] uppercase tracking-wider font-medium mb-2">Mon approche</div>
              <ul class="text-sm text-gray-400 space-y-1.5">
                <li class="flex items-start gap-2"><span class="text-[#22C55E] mt-0.5">&#10003;</span> 5-8 plugins maximum, audites</li>
                <li class="flex items-start gap-2"><span class="text-[#22C55E] mt-0.5">&#10003;</span> Theme code a la main (&lt;200KB)</li>
                <li class="flex items-start gap-2"><span class="text-[#22C55E] mt-0.5">&#10003;</span> Architecture stable et testee</li>
                <li class="flex items-start gap-2"><span class="text-[#22C55E] mt-0.5">&#10003;</span> Score Lighthouse 90+</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES DETAIL -->
  <section class="py-24 px-6 md:px-12 bg-[#F7F7F7]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Services</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]" style="line-height:1.1;">
          Ce que je developpe
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        {[
          {
            title: 'Theme sur mesure',
            desc: 'Design unique, code propre, champs ACF personnalises. Votre site ne ressemble a aucun autre. Interface d\'administration intuitive pour gerer votre contenu en autonomie.',
            tags: ['PHP', 'ACF Pro', 'Gutenberg', 'SASS'],
            dark: false
          },
          {
            title: 'WooCommerce',
            desc: 'Boutique en ligne performante : catalogue produits, gestion stock, paiements securises, livraison. Configuration complete et optimisee pour la conversion.',
            tags: ['WooCommerce', 'Stripe', 'PayPal', 'SMTP'],
            dark: false
          },
          {
            title: 'Migration & Refonte',
            desc: 'Votre site actuel est lent ou obsolete ? Je migre votre contenu et reconstruis un theme performant sans perdre votre referencement.',
            tags: ['Migration SEO', 'Redirections 301', 'Import/Export'],
            dark: true
          },
          {
            title: 'Maintenance & Securite',
            desc: 'Mises a jour regulieres, sauvegardes automatiques, monitoring securite, certificat SSL. Votre site reste performant et protege dans le temps.',
            tags: ['Updates', 'Backups', 'SSL', 'Monitoring'],
            dark: false
          },
        ].map(service => (
          <div class={`reveal rounded-2xl transition-all duration-300 flex flex-col justify-between min-h-[280px] p-8 md:p-10 ${service.dark ? 'bg-[#141414] text-white' : 'border border-[#E5E5E5] bg-white text-[#1A1A1A] hover:border-[#ccc] hover:shadow-lg'}`}>
            <div>
              <h3 class="text-xl font-bold mb-3">{service.title}</h3>
              <p class={`text-sm leading-relaxed mb-6 ${service.dark ? 'text-gray-400' : 'text-[#6B6B6B]'}`}>{service.desc}</p>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {service.tags.map(tag => (
                <span class={`text-[10px] px-2.5 py-1 rounded-full ${service.dark ? 'text-gray-400 border border-white/10 bg-white/5' : 'text-[#6B6B6B] border border-[#E5E5E5] bg-[#F7F7F7]'}`}>{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="py-24 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Processus</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]" style="line-height:1.1;">
          Comment ca se passe
        </h2>
      </div>

      <div class="space-y-0">
        {[
          {
            num: '01',
            title: 'Brief & Benchmark',
            desc: 'On echange sur votre activite, vos objectifs, votre cible. J\'analyse votre secteur et vos concurrents pour definir le meilleur positionnement.',
            duration: '1-2 jours'
          },
          {
            num: '02',
            title: 'Maquettes & Arborescence',
            desc: 'Structure du site, wireframes, puis maquettes haute fidelite. Chaque page est pensee pour convertir vos visiteurs en clients.',
            duration: '3-5 jours'
          },
          {
            num: '03',
            title: 'Developpement du theme',
            desc: 'Code du theme WordPress from scratch. Integration pixel perfect, champs ACF, responsive design, optimisation des images et du cache.',
            duration: '1-3 semaines'
          },
          {
            num: '04',
            title: 'Contenu & Formation',
            desc: 'Integration de vos contenus, SEO on-page, et formation a l\'utilisation du back-office. Vous etes autonome pour gerer votre site.',
            duration: '2-3 jours'
          },
          {
            num: '05',
            title: 'Lancement & Suivi',
            desc: 'Mise en ligne, configuration DNS, analytics, Search Console. Suivi post-lancement pour s\'assurer que tout tourne parfaitement.',
            duration: '1-2 jours'
          },
        ].map(step => (
          <div class="reveal flex flex-col sm:flex-row sm:items-start py-12 border-b border-[#E5E5E5] last:border-0 gap-6 sm:gap-12">
            <div class="flex items-start gap-6 flex-1">
              <span class="serif-italic text-5xl md:text-6xl text-[#1A1A1A]/10 flex-shrink-0 leading-none">{step.num}</span>
              <div>
                <h3 class="text-xl font-bold text-[#1A1A1A] mb-2">{step.title}</h3>
                <p class="text-[#6B6B6B] text-sm leading-relaxed max-w-lg">{step.desc}</p>
              </div>
            </div>
            <div class="flex-shrink-0 sm:text-right">
              <span class="text-[10px] font-medium px-3 py-1.5 rounded-full border border-[#E5E5E5] text-[#6B6B6B] uppercase tracking-wider bg-white">{step.duration}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <section class="py-24 px-6 md:px-12 bg-[#141414]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label--dark mb-6 inline-block" style="display:inline-flex; border:1px solid #333; border-radius:100px; padding:6px 16px; font-size:11px; font-weight:500; letter-spacing:3px; text-transform:uppercase;">Ideal pour</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-white" style="line-height:1.1;">
          Quel site vous correspond ?
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {[
          {
            title: 'Site vitrine',
            desc: 'Presentez votre activite avec un site elegant et rapide. Pages services, a propos, contact, blog. Le standard professionnel.',
            price: 'A partir de 1 500 EUR'
          },
          {
            title: 'E-commerce',
            desc: 'Vendez en ligne avec WooCommerce. Catalogue, panier, paiement, gestion des commandes et livraisons. Pret pour la croissance.',
            price: 'A partir de 3 000 EUR'
          },
          {
            title: 'Site institutionnel',
            desc: 'Multilingue, accessibilite RGAA, volumes de contenu importants. Pour collectivites, associations et grandes structures.',
            price: 'A partir de 5 000 EUR'
          },
        ].map(useCase => (
          <div class="reveal rounded-2xl bg-[#1E1E1E] border border-[#333] hover:border-[#555] transition-all duration-300 p-8 flex flex-col justify-between min-h-[260px]">
            <div>
              <h3 class="text-xl font-bold text-white mb-3">{useCase.title}</h3>
              <p class="text-sm text-gray-400 leading-relaxed">{useCase.desc}</p>
            </div>
            <div class="mt-6 pt-4 border-t border-[#333]">
              <span class="text-sm text-gray-500">{useCase.price}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 px-6 md:px-12 bg-[#F7F7F7]">
    <div class="max-w-3xl mx-auto">
      <div class="reveal mb-16 text-center">
        <span class="section-label mb-6 inline-block">FAQ</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]" style="line-height:1.1;">
          Questions frequentes
        </h2>
      </div>

      <div class="space-y-3">
        {[
          {
            q: 'Pourquoi un theme sur mesure plutot qu\'un theme premium ?',
            a: 'Un theme premium embarque des milliers de lignes de code inutiles pour votre cas. Un theme sur mesure est leger (10x moins de code), charge plus vite, et correspond exactement a vos besoins. C\'est un investissement qui se rentabilise en performances et en SEO.'
          },
          {
            q: 'WordPress est-il encore pertinent en 2026 ?',
            a: 'Absolument. WordPress propulse 43% du web mondial. C\'est la solution ideale quand vous avez besoin d\'une gestion de contenu accessible et d\'un ecosysteme de plugins mature. Pour des besoins plus avances (SaaS, apps), je recommande React/Next.js.'
          },
          {
            q: 'Puis-je gerer mon site seul apres livraison ?',
            a: 'Oui, c\'est le but. L\'interface d\'administration est pensee pour etre intuitive. Je cree des champs personnalises clairs et je vous forme avec un guide et une session video. Vous gerez contenu, images et pages en autonomie.'
          },
          {
            q: 'Combien coute la maintenance mensuelle ?',
            a: 'Les forfaits de maintenance demarrent a 90 EUR/mois et incluent les mises a jour WordPress/plugins, les sauvegardes, le monitoring securite et les petites modifications de contenu. Un site non maintenu est un site vulnerable.'
          },
        ].map(faq => (
          <details class="reveal group rounded-2xl border border-[#E5E5E5] bg-white overflow-hidden">
            <summary class="flex items-center justify-between p-6 cursor-pointer text-[#1A1A1A] font-medium hover:bg-[#FAFAFA] transition-colors">
              <span class="pr-4">{faq.q}</span>
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="flex-shrink-0 transition-transform duration-300 group-open:rotate-45"><path d="M12 5v14M5 12h14"/></svg>
            </summary>
            <div class="px-6 pb-6 text-sm text-[#6B6B6B] leading-relaxed border-t border-[#E5E5E5] pt-4">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Pourquoi un theme sur mesure plutot qu'un theme premium ?", "acceptedAnswer": { "@type": "Answer", "text": "Un theme premium embarque des milliers de lignes de code inutiles. Un theme sur mesure est 10x plus leger, charge plus vite, et correspond exactement a vos besoins." } },
      { "@type": "Question", "name": "WordPress est-il encore pertinent en 2026 ?", "acceptedAnswer": { "@type": "Answer", "text": "Absolument. WordPress propulse 43% du web mondial. C'est la solution ideale pour la gestion de contenu accessible avec un ecosysteme de plugins mature." } },
      { "@type": "Question", "name": "Puis-je gerer mon site seul apres livraison ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui. L'interface d'administration est pensee pour etre intuitive avec des champs personnalises clairs et une formation incluse." } },
      { "@type": "Question", "name": "Combien coute la maintenance mensuelle ?", "acceptedAnswer": { "@type": "Answer", "text": "Les forfaits demarrent a 90 EUR/mois et incluent mises a jour, sauvegardes, monitoring securite et petites modifications." } }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Creation de sites WordPress sur mesure",
    "description": "Themes WordPress codes a la main, WooCommerce, migration et maintenance. Sites performants et securises.",
    "provider": {
      "@type": "ProfessionalService",
      "name": "Stephane Duma — Developpeur Freelance",
      "url": "https://stephduma.dev",
      "address": { "@type": "PostalAddress", "addressLocality": "Perpignan", "addressCountry": "FR" }
    },
    "areaServed": { "@type": "Country", "name": "France" },
    "serviceType": "Creation de site internet"
  })} />

</Layout>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
