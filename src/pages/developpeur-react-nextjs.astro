---
import Layout from '../layouts/Layout.astro';
import ServiceSubNav from '../components/ServiceSubNav.astro';
---

<Layout
  title="Développeur React & Next.js Freelance à Perpignan — Stéphane Duma"
  description="Expert React & Next.js freelance à Perpignan. Applications web performantes, SSR/SSG, SEO optimisé, TypeScript. +10 ans d'expérience, 250+ projets. Devis gratuit."
  canonical="https://stephduma.dev/developpeur-react-nextjs/"
  keywords="développeur react perpignan, développeur next.js freelance, freelance react france, création application web react, développeur frontend perpignan"
>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center px-6 md:px-12 overflow-hidden pt-24" style="background: radial-gradient(ellipse 80% 60% at 30% 50%, #f0f0ee 0%, #e8e8e6 60%, #ddd 100%);">

    <!-- Floating code fragments -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="code-float absolute top-[15%] right-[8%] text-[11px] font-mono text-[#1A1A1A]/[0.07] leading-relaxed select-none" style="transform: rotate(3deg);">
        <pre>const App = () =&gt; {'{'}
  return &lt;Layout&gt;
    &lt;Hero /&gt;
    &lt;Features /&gt;
  &lt;/Layout&gt;
{'}'}</pre>
      </div>
      <div class="code-float-reverse absolute bottom-[20%] left-[5%] text-[10px] font-mono text-[#1A1A1A]/[0.05] leading-relaxed select-none" style="transform: rotate(-2deg);">
        <pre>export async function
  getServerSideProps() {'{'}
  const data = await
    fetch(API_URL)
  return {'{'} props: {'{'} data {'}'} {'}'}
{'}'}</pre>
      </div>
      <div class="code-float absolute top-[60%] right-[15%] text-[9px] font-mono text-[#1A1A1A]/[0.04] leading-relaxed select-none" style="transform: rotate(1deg);">
        <pre>useEffect(() =&gt; {'{'}
  fetchData()
{'}'}, [])</pre>
      </div>
    </div>

    <!-- Geometric accent -->
    <div class="absolute top-[10%] right-[12%] w-[300px] h-[300px] md:w-[500px] md:h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(26,26,26,0.03) 0%, transparent 70%);"></div>

    <div class="max-w-6xl mx-auto w-full relative z-10">
      <div class="max-w-4xl">
        <!-- Breadcrumb -->
        <div class="reveal flex items-center gap-2 text-xs text-[#A0A0A0] mb-8" style="font-family:'DM Sans',sans-serif; letter-spacing:1px;">
          <a href="/" class="hover:text-[#1A1A1A] transition-colors">Accueil</a>
          <span>/</span>
          <a href="/#services" class="hover:text-[#1A1A1A] transition-colors">Services</a>
          <span>/</span>
          <span class="text-[#1A1A1A]">React & Next.js</span>
        </div>

        <ServiceSubNav active="/developpeur-react-nextjs" variant="light" />

        <h1 class="reveal text-[#1A1A1A] leading-[0.92] mb-8" style="font-family:'Playfair Display',serif; font-size:clamp(2.8rem,8vw,7rem); font-weight:900; letter-spacing:-2px;">
          Applications web<br/>
          <span class="relative inline-block">
            performantes
            <span class="absolute -bottom-2 left-0 w-full h-[3px] bg-[#1A1A1A]/10 rounded-full"></span>
          </span>
        </h1>

        <p class="reveal text-[#6B6B6B] text-lg md:text-xl leading-relaxed max-w-2xl mb-12">
          Je conçois des applications React & Next.js rapides, accessibles et optimisées pour le SEO. Du MVP au produit scalé, avec une architecture pensée pour durer.
        </p>

        <div class="reveal flex flex-wrap items-center gap-4">
          <a href="/#contact" class="inline-flex items-center gap-3 px-7 py-3.5 bg-[#1A1A1A] text-white rounded-full text-sm font-medium hover:bg-[#333] transition-all duration-300 hover:gap-5 group">
            Discuter de votre projet
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="group-hover:rotate-45 transition-transform duration-300"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
          <a href="#process" class="inline-flex items-center gap-2 px-7 py-3.5 border border-[#E5E5E5] rounded-full text-sm text-[#6B6B6B] hover:border-[#1A1A1A] hover:text-[#1A1A1A] transition-all duration-300">
            Voir ma méthode
          </a>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="reveal mt-20 pt-8 border-t border-[#D8D8D8]">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div>
            <div class="serif-italic text-4xl md:text-5xl text-[#1A1A1A]">100+</div>
            <div class="text-sm text-[#6B6B6B] mt-2">Apps React livrées</div>
          </div>
          <div>
            <div class="serif-italic text-4xl md:text-5xl text-[#1A1A1A]">98+</div>
            <div class="text-sm text-[#6B6B6B] mt-2">Score Lighthouse moyen</div>
          </div>
          <div>
            <div class="serif-italic text-4xl md:text-5xl text-[#1A1A1A]">&lt;1s</div>
            <div class="text-sm text-[#6B6B6B] mt-2">First Contentful Paint</div>
          </div>
          <div>
            <div class="serif-italic text-4xl md:text-5xl text-[#1A1A1A]">SEO</div>
            <div class="text-sm text-[#6B6B6B] mt-2">Optimisé nativement</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EXPERTISE AREAS -->
  <section class="py-24 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Expertise</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]" style="line-height:1.1;">
          Ce que je maîtrise
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <!-- Card 1: Next.js App Router -->
        <div class="reveal group rounded-2xl border border-[#E5E5E5] hover:border-[#ccc] hover:shadow-lg transition-all duration-500 p-8 bg-white relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 pointer-events-none" style="background: radial-gradient(circle at top right, rgba(26,26,26,0.03), transparent 70%);"></div>
          <div class="w-12 h-12 rounded-xl bg-[#1A1A1A] flex items-center justify-center mb-6">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3 class="text-lg font-bold text-[#1A1A1A] mb-3">Next.js App Router</h3>
          <p class="text-sm text-[#6B6B6B] leading-relaxed mb-6">Server Components, Streaming SSR, ISR, Parallel Routes. J'utilise les dernières fonctionnalités pour des apps ultra-rapides.</p>
          <div class="flex flex-wrap gap-1.5">
            {['SSR', 'SSG', 'ISR', 'RSC', 'Streaming'].map(tag => (
              <span class="text-[10px] text-[#6B6B6B] px-2.5 py-1 rounded-full border border-[#E5E5E5] bg-[#F7F7F7]">{tag}</span>
            ))}
          </div>
        </div>

        <!-- Card 2: React Ecosysteme -->
        <div class="reveal group rounded-2xl border border-[#E5E5E5] hover:border-[#ccc] hover:shadow-lg transition-all duration-500 p-8 bg-white relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 pointer-events-none" style="background: radial-gradient(circle at top right, rgba(26,26,26,0.03), transparent 70%);"></div>
          <div class="w-12 h-12 rounded-xl bg-[#1A1A1A] flex items-center justify-center mb-6">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1C7 1 3 5.5 3 12s4 11 9 11 9-4.5 9-11S17 1 12 1z"/><path d="M1 12h22"/></svg>
          </div>
          <h3 class="text-lg font-bold text-[#1A1A1A] mb-3">Écosystème React</h3>
          <p class="text-sm text-[#6B6B6B] leading-relaxed mb-6">Hooks avancés, Context, Zustand, React Query, Suspense. Architecture modulaire et patterns éprouvés.</p>
          <div class="flex flex-wrap gap-1.5">
            {['Hooks', 'Zustand', 'React Query', 'Suspense', 'Zod'].map(tag => (
              <span class="text-[10px] text-[#6B6B6B] px-2.5 py-1 rounded-full border border-[#E5E5E5] bg-[#F7F7F7]">{tag}</span>
            ))}
          </div>
        </div>

        <!-- Card 3: TypeScript & DX -->
        <div class="reveal group rounded-2xl bg-[#141414] hover:shadow-lg transition-all duration-500 p-8 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 pointer-events-none" style="background: radial-gradient(circle at top right, rgba(255,255,255,0.03), transparent 70%);"></div>
          <div class="w-12 h-12 rounded-xl bg-white/10 border border-white/20 flex items-center justify-center mb-6">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-3">TypeScript & Qualité</h3>
          <p class="text-sm text-gray-400 leading-relaxed mb-6">Typage strict, tests unitaires, CI/CD. Du code maintenable, documenté, et prêt pour l'équipe qui prend la suite.</p>
          <div class="flex flex-wrap gap-1.5">
            {['TypeScript', 'Vitest', 'ESLint', 'CI/CD', 'Sentry'].map(tag => (
              <span class="text-[10px] text-gray-400 px-2.5 py-1 rounded-full border border-white/10 bg-white/5">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section id="process" class="py-24 px-6 md:px-12 bg-[#F7F7F7]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Méthode</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]" style="line-height:1.1;">
          Du brief au déploiement
        </h2>
      </div>

      <div class="space-y-0">
        {[
          {
            num: '01',
            title: 'Découverte & Cadrage',
            desc: 'On définit ensemble les objectifs, le périmètre et les contraintes. Je vous propose une architecture technique adaptée à vos ambitions et votre budget.',
            duration: '1-2 jours'
          },
          {
            num: '02',
            title: 'Design & Prototypage',
            desc: 'Wireframes, maquettes et prototype interactif. Vous validez chaque écran avant que je code une seule ligne. Pas de mauvaises surprises.',
            duration: '3-5 jours'
          },
          {
            num: '03',
            title: 'Développement & Itérations',
            desc: 'Sprints courts avec démos régulières. Chaque fonctionnalité est testée, optimisée et déployée en preview pour que vous suiviez l\'avancement en temps réel.',
            duration: '2-6 semaines'
          },
          {
            num: '04',
            title: 'Tests & Mise en production',
            desc: 'Tests cross-navigateurs, audit Lighthouse, optimisation SEO, configuration domaine et analytics. Votre app est en ligne, rapide, et monitorée.',
            duration: '2-3 jours'
          },
        ].map(step => (
          <div class="reveal flex flex-col sm:flex-row sm:items-start py-12 border-b border-[#E5E5E5] last:border-0 gap-6 sm:gap-12">
            <div class="flex items-start gap-6 flex-1">
              <span class="serif-italic text-5xl md:text-6xl text-[#1A1A1A]/10 flex-shrink-0 leading-none">{step.num}</span>
              <div>
                <h3 class="text-xl font-bold text-[#1A1A1A] mb-2">{step.title}</h3>
                <p class="text-[#6B6B6B] text-sm leading-relaxed max-w-lg">{step.desc}</p>
              </div>
            </div>
            <div class="flex-shrink-0 sm:text-right">
              <span class="text-[10px] font-medium px-3 py-1.5 rounded-full border border-[#E5E5E5] text-[#6B6B6B] uppercase tracking-wider bg-white">{step.duration}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TECH STACK — visual grid -->
  <section class="py-24 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Stack technique</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]" style="line-height:1.1;">
          Les outils que j'utilise
        </h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { name: 'React', slug: 'react', desc: 'UI Components' },
          { name: 'Next.js', slug: 'nextdotjs', desc: 'Framework Full-Stack' },
          { name: 'TypeScript', slug: 'typescript', desc: 'Typage statique' },
          { name: 'Tailwind CSS', slug: 'tailwindcss', desc: 'Styling utilitaire' },
          { name: 'Vercel', slug: 'vercel', desc: 'Déploiement & CDN' },
          { name: 'Supabase', slug: 'supabase', desc: 'Backend-as-a-Service' },
          { name: 'Stripe', slug: 'stripe', desc: 'Paiements' },
          { name: 'Figma', slug: 'figma', desc: 'Design & Prototypage' },
        ].map(tech => (
          <div class="reveal group flex flex-col items-center text-center p-6 rounded-2xl border border-[#E5E5E5] hover:border-[#ccc] hover:shadow-md transition-all duration-300 bg-white">
            <img
              src={`https://cdn.simpleicons.org/${tech.slug}/1A1A1A`}
              alt={tech.name}
              width="32"
              height="32"
              class="mb-4 opacity-60 group-hover:opacity-100 transition-opacity duration-300"
              loading="lazy"
              decoding="async"
            />
            <div class="text-sm font-bold text-[#1A1A1A] mb-1">{tech.name}</div>
            <div class="text-[11px] text-[#A0A0A0]">{tech.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <section class="py-24 px-6 md:px-12 bg-[#141414]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label--dark mb-6 inline-block" style="display:inline-flex; border:1px solid #333; border-radius:100px; padding:6px 16px; font-size:11px; font-weight:500; letter-spacing:3px; text-transform:uppercase;">Cas d'usage</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-white" style="line-height:1.1;">
          Pour quel projet ?
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        {[
          {
            title: 'Site vitrine premium',
            desc: 'Un site qui vous représente vraiment. Animations soignées, performances maximales, SEO au top. Idéal pour freelances, agences et PME.',
            icon: '&#9670;'
          },
          {
            title: 'Application SaaS',
            desc: 'Dashboard, authentification, paiements Stripe, API temps reel. Architecture scalable pensée pour la croissance.',
            icon: '&#9671;'
          },
          {
            title: 'E-commerce headless',
            desc: 'Shopify, Snipcart ou custom. Catalogue produits, panier, checkout et gestion commandes avec des performances imbattables.',
            icon: '&#9651;'
          },
          {
            title: 'Landing page conversion',
            desc: 'Pages d\'atterrissage ultra-rapides pour vos campagnes. A/B testing, analytics intégrés, taux de conversion optimisé.',
            icon: '&#9711;'
          },
        ].map(useCase => (
          <div class="reveal rounded-2xl bg-[#1E1E1E] border border-[#333] hover:border-[#555] transition-all duration-300 p-8 group">
            <div class="text-2xl text-white/20 mb-4 group-hover:text-white/40 transition-colors duration-300" set:html={useCase.icon} />
            <h3 class="text-xl font-bold text-white mb-3">{useCase.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed">{useCase.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING HINT -->
  <section class="py-24 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-4xl mx-auto">
      <div class="reveal text-center mb-16">
        <span class="section-label mb-6 inline-block">Tarifs</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]" style="line-height:1.1;">
          Un investissement, pas un coût
        </h2>
        <p class="text-[#6B6B6B] mt-6 max-w-2xl mx-auto leading-relaxed">
          Chaque projet est unique. Je propose un devis détaillé et transparent après notre premier échange. Voici des fourchettes indicatives.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="reveal rounded-2xl border border-[#E5E5E5] p-8 text-center hover:shadow-lg transition-all duration-300">
          <div class="text-xs text-[#A0A0A0] uppercase tracking-wider mb-4">Site vitrine</div>
          <div class="serif-italic text-5xl text-[#1A1A1A] mb-2">2-5k</div>
          <div class="text-sm text-[#6B6B6B] mb-6">euros</div>
          <ul class="text-sm text-[#6B6B6B] space-y-2 text-left">
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-[#1A1A1A] mt-2 flex-shrink-0"></span>3-6 pages</li>
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-[#1A1A1A] mt-2 flex-shrink-0"></span>Design sur mesure</li>
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-[#1A1A1A] mt-2 flex-shrink-0"></span>SEO optimisé</li>
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-[#1A1A1A] mt-2 flex-shrink-0"></span>Déploiement Vercel</li>
          </ul>
        </div>

        <div class="reveal rounded-2xl bg-[#141414] p-8 text-center hover:shadow-lg transition-all duration-300 relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="text-[10px] font-medium px-3 py-1 rounded-full bg-[#1A1A1A] text-white border border-[#333] uppercase tracking-wider">Populaire</span>
          </div>
          <div class="text-xs text-gray-500 uppercase tracking-wider mb-4">Application web</div>
          <div class="serif-italic text-5xl text-white mb-2">5-15k</div>
          <div class="text-sm text-gray-400 mb-6">euros</div>
          <ul class="text-sm text-gray-400 space-y-2 text-left">
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-white mt-2 flex-shrink-0"></span>Application complète</li>
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-white mt-2 flex-shrink-0"></span>Auth & dashboard</li>
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-white mt-2 flex-shrink-0"></span>API & base de données</li>
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-white mt-2 flex-shrink-0"></span>Paiements Stripe</li>
          </ul>
        </div>

        <div class="reveal rounded-2xl border border-[#E5E5E5] p-8 text-center hover:shadow-lg transition-all duration-300">
          <div class="text-xs text-[#A0A0A0] uppercase tracking-wider mb-4">SaaS / Sur mesure</div>
          <div class="serif-italic text-5xl text-[#1A1A1A] mb-2">15k+</div>
          <div class="text-sm text-[#6B6B6B] mb-6">euros</div>
          <ul class="text-sm text-[#6B6B6B] space-y-2 text-left">
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-[#1A1A1A] mt-2 flex-shrink-0"></span>Architecture scalable</li>
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-[#1A1A1A] mt-2 flex-shrink-0"></span>Multi-tenant</li>
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-[#1A1A1A] mt-2 flex-shrink-0"></span>i18n & multi-devises</li>
            <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-[#1A1A1A] mt-2 flex-shrink-0"></span>Support & maintenance</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ with Schema -->
  <section class="py-24 px-6 md:px-12 bg-[#F7F7F7]">
    <div class="max-w-3xl mx-auto">
      <div class="reveal mb-16 text-center">
        <span class="section-label mb-6 inline-block">FAQ</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]" style="line-height:1.1;">
          Questions fréquentes
        </h2>
      </div>

      <div class="space-y-3">
        {[
          {
            q: 'Pourquoi choisir React & Next.js plutôt qu\'un CMS classique ?',
            a: 'React & Next.js offrent des performances supérieures (temps de chargement, SEO), une flexibilité totale sur le design et les fonctionnalités, et une architecture qui scale avec votre activité. Pour un site vitrine simple, un CMS peut suffire. Pour tout le reste, React est le choix professionnel.'
          },
          {
            q: 'Combien de temps prend le développement d\'une application ?',
            a: 'Un site vitrine : 2-4 semaines. Une application web avec auth et dashboard : 4-8 semaines. Un SaaS complet : 2-4 mois. Ces délais incluent le design, le développement, les tests et le déploiement.'
          },
          {
            q: 'Est-ce que je pourrai modifier le contenu moi-même ?',
            a: 'Oui. Selon le projet, j\'intègre un CMS headless (Sanity, Strapi, ou Notion) qui vous permet de modifier textes, images et pages sans toucher au code. Je vous forme à son utilisation.'
          },
          {
            q: 'Que se passe-t-il après la mise en ligne ?',
            a: 'Je propose un suivi post-lancement : monitoring des performances, corrections de bugs, et évolutions. Des forfaits de maintenance mensuels sont disponibles selon vos besoins.'
          },
        ].map(faq => (
          <details class="reveal group rounded-2xl border border-[#E5E5E5] bg-white overflow-hidden">
            <summary class="flex items-center justify-between p-6 cursor-pointer text-[#1A1A1A] font-medium hover:bg-[#FAFAFA] transition-colors">
              <span class="pr-4">{faq.q}</span>
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="flex-shrink-0 transition-transform duration-300 group-open:rotate-45"><path d="M12 5v14M5 12h14"/></svg>
            </summary>
