---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Stéphane Duma — Développeur Frontend Expert</title>
  <meta name="description" content="Développeur Frontend Expert React, Next.js & WordPress. +10 ans d'expérience, 57 projets livrés. Basé à Perpignan." />
  <meta property="og:title" content="Stéphane Duma — Développeur Frontend Expert" />
  <meta property="og:description" content="Développeur Frontend Expert React, Next.js & WordPress. +10 ans d'expérience, 57 projets livrés." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://stephduma.dev" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- NAV -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-6 px-6 md:px-12">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="#" class="text-xl font-bold tracking-tight" style="font-family:'Bebas Neue',sans-serif; font-size: 1.5rem; letter-spacing: 0.05em;">SD</a>
      <div class="hidden md:flex items-center gap-8 text-sm text-gray-400">
        <a href="#about" class="hover:text-white transition-colors">À propos</a>
        <a href="#services" class="hover:text-white transition-colors">Services</a>
        <a href="#experience" class="hover:text-white transition-colors">Expérience</a>
        <a href="#portfolio" class="hover:text-white transition-colors">Portfolio</a>
      </div>
      <a href="#contact" class="hidden md:inline-flex items-center gap-2 px-4 py-2 border border-white/20 rounded-full text-sm hover:bg-white hover:text-black transition-all duration-300">
        Me contacter
      </a>
      <button id="menu-btn" class="md:hidden p-2 text-gray-400 hover:text-white">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-white/10 pt-4">
      <div class="flex flex-col gap-4 text-sm">
        <a href="#about" class="text-gray-400 hover:text-white transition-colors">À propos</a>
        <a href="#services" class="text-gray-400 hover:text-white transition-colors">Services</a>
        <a href="#experience" class="text-gray-400 hover:text-white transition-colors">Expérience</a>
        <a href="#portfolio" class="text-gray-400 hover:text-white transition-colors">Portfolio</a>
        <a href="#contact" class="text-gray-400 hover:text-white transition-colors">Contact</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-center px-6 md:px-12 pt-24 pb-12">
    <div class="max-w-6xl mx-auto w-full">
      <div id="hero-content">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/10 text-xs text-gray-400 mb-8" id="badge">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          DISPONIBLE POUR PROJETS
        </div>
        <h1 class="hero-title text-[clamp(4rem,12vw,10rem)] leading-none font-black tracking-tight mb-6 overflow-hidden" style="font-family:'Bebas Neue',sans-serif;">
          <span class="block">Développeur</span>
          <span class="block text-gray-500">Frontend</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-400 max-w-xl mb-12" id="hero-sub">
          Je crée des expériences web qui font la différence — rapides, accessibles, mémorables.
        </p>
        <div class="flex flex-wrap gap-8 text-sm" id="hero-stats">
          <div>
            <div class="text-3xl font-bold text-white">10+</div>
            <div class="text-gray-500 mt-1">Ans d'expérience</div>
          </div>
          <div class="w-px bg-white/10"></div>
          <div>
            <div class="text-3xl font-bold text-white">57</div>
            <div class="text-gray-500 mt-1">Projets livrés</div>
          </div>
          <div class="w-px bg-white/10"></div>
          <div>
            <div class="text-3xl font-bold text-white">50+</div>
            <div class="text-gray-500 mt-1">Clients satisfaits</div>
          </div>
        </div>
        <div class="mt-16 flex items-center gap-2 text-gray-600 text-sm">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
          Défiler pour explorer
        </div>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="py-8 border-y border-white/5 overflow-hidden">
    <div class="marquee-track gap-12 items-center" style="will-change:transform;">
      {['React', 'Next.js', 'WordPress', 'Tailwind', 'TypeScript', 'Supabase', 'Node.js', 'Vercel', 'GSAP', 'Figma', 'React', 'Next.js', 'WordPress', 'Tailwind', 'TypeScript', 'Supabase', 'Node.js', 'Vercel', 'GSAP', 'Figma'].map(tech => (
        <span class="text-gray-600 font-medium text-sm whitespace-nowrap px-6 uppercase tracking-widest">{tech}</span>
      ))}
    </div>
  </div>

  <!-- ABOUT -->
  <section id="about" class="py-24 px-6 md:px-12">
    <div class="max-w-6xl mx-auto">
      <div class="reveal grid md:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-xs text-gray-500 tracking-widest uppercase mb-4 block">À propos</span>
          <h2 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
            Le code, c'est mon obsession depuis plus d'une décennie.
          </h2>
          <p class="text-gray-400 leading-relaxed mb-6">
            Développeur frontend expert basé à Perpignan, je transforme des idées complexes en interfaces simples et performantes. Spécialisé React, Next.js et WordPress, je travaille avec des startups et PME qui veulent un vrai partenaire technique — pas juste un prestataire.
          </p>
          <a href="#contact" class="inline-flex items-center gap-2 text-sm text-emerald-400 hover:gap-4 transition-all duration-300">
            Travaillons ensemble
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { num: '10+', label: 'Années d\'expérience' },
            { num: '57', label: 'Projets livrés' },
            { num: '50+', label: 'Clients heureux' },
            { num: '3', label: 'Pays clients' },
          ].map(stat => (
            <div class="p-6 border border-white/5 rounded-2xl hover:border-white/10 transition-colors">
              <div class="text-4xl font-bold mb-2" style="font-family:'Bebas Neue',sans-serif;">{stat.num}</div>
              <div class="text-gray-500 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="py-24 px-6 md:px-12 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="text-xs text-gray-500 tracking-widest uppercase mb-4 block">Services</span>
        <h2 class="text-4xl md:text-5xl font-bold">Ce que j'apporte</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {[
          {
            num: '01',
            title: 'Sites React & Next.js',
            desc: 'Applications web performantes, SSR, SSG, SEO optimisé. Du MVP à la production, avec une architecture solide et maintenable.',
            tag: 'React · Next.js · TypeScript'
          },
          {
            num: '02',
            title: 'Thèmes WordPress',
            desc: 'Thèmes sur mesure, performants et maintenables. WooCommerce, ACF, Gutenberg. Pas de page builders, du vrai code.',
            tag: 'WordPress · PHP · WooCommerce'
          },
          {
            num: '03',
            title: 'Intégrations & APIs',
            desc: 'Connexion de vos outils : Supabase, Stripe, CRMs, outils IA. Je fais parler vos systèmes entre eux.',
            tag: 'Supabase · Stripe · REST · GraphQL'
          },
          {
            num: '04',
            title: 'Performance & Accessibilité',
            desc: 'Audits Core Web Vitals, optimisation images, lazy loading, accessibilité RGAA. Des sites rapides, pour tout le monde.',
            tag: 'Lighthouse · RGAA · SEO'
          },
        ].map((service, i) => (
          <div class={`reveal service-card p-8 rounded-2xl border border-white/5 hover:border-white/15 transition-all duration-500 group cursor-default ${i === 2 ? 'md:bg-white md:text-black' : ''}`}>
            <div class={`text-xs font-mono mb-6 ${i === 2 ? 'text-gray-400 md:text-gray-500' : 'text-gray-600'}`}>{service.num}</div>
            <h3 class="text-xl font-bold mb-3 group-hover:translate-x-1 transition-transform duration-300">{service.title}</h3>
            <p class={`text-sm leading-relaxed mb-6 ${i === 2 ? 'text-gray-500 md:text-gray-600' : 'text-gray-500'}`}>{service.desc}</p>
            <span class={`text-xs font-mono ${i === 2 ? 'text-gray-400 md:text-gray-500' : 'text-gray-600'}`}>{service.tag}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section id="experience" class="py-24 px-6 md:px-12 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="text-xs text-gray-500 tracking-widest uppercase mb-4 block">Expérience</span>
        <h2 class="text-4xl md:text-5xl font-bold">Une décennie<br/>de croissance</h2>
      </div>
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-0 top-0 bottom-0 w-px bg-white/5 ml-4 md:ml-0 md:left-[4.5rem]" id="timeline-line" style="transform-origin:top; transform:scaleY(0);"></div>
        <div class="space-y-0">
          {[
            { num: '01', period: '2014 – 2018', role: 'Développeur WordPress', desc: 'Création de thèmes et plugins WordPress sur mesure. Clients e-commerce, institutions, startups françaises.' },
            { num: '02', period: '2018 – 2022', role: 'Développeur React & Frontend', desc: 'Migration vers React et l\'écosystème JavaScript moderne. Intégrations API, applications SPA complexes, travail en équipe agile.' },
            { num: '03', period: '2022 – Présent', role: 'Développeur Next.js & Solutions IA', desc: 'Spécialisation Next.js App Router, Supabase, intégrations IA. Création de SaaS, outils métier et sites ultra-performants.' },
          ].map(exp => (
            <div class="reveal flex gap-8 md:gap-16 py-12 border-b border-white/5 last:border-0 pl-12 md:pl-0">
              <div class="hidden md:block w-16 flex-shrink-0 text-right">
                <span class="text-xs font-mono text-gray-600">{exp.num}</span>
              </div>
              <div class="flex-1 grid md:grid-cols-3 gap-4 items-start">
                <div>
                  <div class="text-xs text-gray-600 font-mono mb-2">{exp.period}</div>
                </div>
                <div class="md:col-span-2">
                  <h3 class="text-xl font-bold mb-3">{exp.role}</h3>
                  <p class="text-gray-400 text-sm leading-relaxed">{exp.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO -->
  <section id="portfolio" class="py-24 px-6 md:px-12 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="text-xs text-gray-500 tracking-widest uppercase mb-4 block">Portfolio</span>
        <h2 class="text-4xl md:text-5xl font-bold">Projets sélectionnés</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-4">
        {[
          { name: 'DigitalQT', desc: 'SaaS tout-en-un pour agences web — dashboard, monitoring, SEO', tags: ['Next.js', 'Supabase', 'Stripe'], year: '2025' },
          { name: 'Cinq Mars', desc: 'Site vitrine haut de gamme pour agence immobilière de prestige', tags: ['WordPress', 'ACF', 'Custom Theme'], year: '2024' },
          { name: 'Cactus Shop', desc: 'E-commerce spécialisé plantes — WooCommerce full custom', tags: ['WooCommerce', 'React', 'REST API'], year: '2024' },
          { name: 'DQT Dashboard', desc: 'Interface client avec analytics temps réel et gestion de tickets', tags: ['Next.js', 'Shadcn/UI', 'Recharts'], year: '2025' },
          { name: 'DICASTRI 2026', desc: 'Plateforme institutionnelle multilingue avec CMS headless', tags: ['Next.js', 'i18n', 'Sanity'], year: '2025' },
          { name: 'i2t', desc: 'Application de traduction assistée par IA pour équipes bilingues', tags: ['React', 'OpenAI', 'Node.js'], year: '2024' },
        ].map(project => (
          <div class="reveal portfolio-card group relative overflow-hidden rounded-2xl border border-white/5 hover:border-white/15 transition-all duration-500 cursor-pointer">
            <div class="aspect-[4/3] bg-gradient-to-br from-gray-900 to-gray-800 flex items-center justify-center p-8">
              <span class="text-3xl font-bold text-white/10 group-hover:text-white/20 transition-all duration-500" style="font-family:'Bebas Neue',sans-serif;">{project.name}</span>
            </div>
            <div class="absolute inset-0 bg-black/80 opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col justify-end p-6">
              <h3 class="font-bold text-white mb-2">{project.name}</h3>
              <p class="text-gray-300 text-xs mb-3 leading-relaxed">{project.desc}</p>
              <div class="flex flex-wrap gap-1">
                {project.tags.map(tag => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-white/10 text-gray-300">{tag}</span>
                ))}
              </div>
              <div class="text-gray-600 text-xs mt-3 font-mono">{project.year}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-24 px-6 md:px-12 border-t border-white/5">
    <div class="max-w-4xl mx-auto">
      <div class="reveal text-center">
        <div class="text-4xl text-gray-700 mb-8">"</div>
        <blockquote class="text-2xl md:text-3xl font-medium leading-relaxed text-white mb-8">
          Stéphane a transformé notre site en quelques semaines. Résultat au-delà de nos attentes — rapide, beau, et vraiment facile à prendre en main.
        </blockquote>
        <div class="flex items-center justify-center gap-4">
          <div class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center text-sm font-bold">JM</div>
          <div class="text-left">
            <div class="text-sm font-medium">Jean-Marc</div>
            <div class="text-xs text-gray-500">Dirigeant, PME e-commerce</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-24 px-6 md:px-12 border-t border-white/5">
    <div class="max-w-4xl mx-auto">
      <div class="reveal text-center">
        <span class="text-xs text-gray-500 tracking-widest uppercase mb-6 block">Contact</span>
        <h2 class="text-5xl md:text-7xl font-bold mb-8 leading-none" style="font-family:'Bebas Neue',sans-serif;">
          Travaillons<br/>ensemble
        </h2>
        <p class="text-gray-400 mb-10 max-w-md mx-auto">
          Un projet en tête ? Parlons-en. Je réponds sous 24h.
        </p>
        <a
          href="mailto:me@stephduma.dev"
          class="inline-flex items-center gap-3 px-8 py-4 bg-white text-black font-medium rounded-full hover:bg-gray-100 transition-all duration-300 hover:gap-5 group"
        >
          me@stephduma.dev
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="group-hover:rotate-45 transition-transform duration-300"><path d="M7 17L17 7M7 7h10v10"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="py-12 px-6 md:px-12 border-t border-white/5">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-sm text-gray-600">
        Stéphane Duma © 2026 · Tous droits réservés
      </div>
      <div class="flex items-center gap-6 text-sm text-gray-600">
        <a href="https://github.com/Agalaxie" target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>
        <a href="https://malt.fr" target="_blank" rel="noopener" class="hover:text-white transition-colors">Malt</a>
        <a href="https://linkedin.com" target="_blank" rel="noopener" class="hover:text-white transition-colors">LinkedIn</a>
      </div>
    </div>
  </footer>

</body>
</html>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  ScrollTrigger.create({
    start: 'top -80',
    onUpdate: (self) => {
      if (self.progress > 0) {
        navbar?.classList.add('bg-black/80', 'backdrop-blur-md', 'border-b', 'border-white/5', 'py-4');
        navbar?.classList.remove('py-6');
      } else {
        navbar?.classList.remove('bg-black/80', 'backdrop-blur-md', 'border-b', 'border-white/5', 'py-4');
        navbar?.classList.add('py-6');
      }
    }
  });

  // Hero entrance animation
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  tl.from('#badge', { y: 20, opacity: 0, duration: 0.6 })
    .from('.hero-title span', { y: '100%', opacity: 0, duration: 0.8, stagger: 0.1 }, '-=0.2')
    .from('#hero-sub', { y: 30, opacity: 0, duration: 0.7 }, '-=0.4')
    .from('#hero-stats > *', { y: 20, opacity: 0, duration: 0.5, stagger: 0.1 }, '-=0.3');

  // Scroll reveal
  gsap.utils.toArray('.reveal').forEach((el: any) => {
    gsap.from(el, {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        once: true,
      }
    });
  });

  // Timeline line animation
  const timelineLine = document.getElementById('timeline-line');
  if (timelineLine) {
    gsap.to(timelineLine, {
      scaleY: 1,
      duration: 1.5,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#experience',
        start: 'top 60%',
        once: true,
      }
    });
  }

  // Mobile menu
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => mobileMenu?.classList.add('hidden'));
  });
</script>
