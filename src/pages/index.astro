<body>

  <!-- NAV — white bg -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-5 px-6 md:px-12" style="background:#f0f0ee;">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="#" class="flex items-center" aria-label="Stéphane Duma — Accueil">
        <span class="inline-flex items-center justify-center w-[38px] h-[38px] rounded-[10px] bg-[#1A1A1A]" style="font-family:'Playfair Display',serif; font-size:16px; font-weight:700; color:#fff; letter-spacing:-0.5px;">SD</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-[#6B6B6B]">
        <a href="#about" class="hover:text-[#1A1A1A] transition-colors">À propos</a>
        <a href="#services" class="hover:text-[#1A1A1A] transition-colors">Services</a>
        <a href="#experience" class="hover:text-[#1A1A1A] transition-colors">Expérience</a>
        <a href="#portfolio" class="hover:text-[#1A1A1A] transition-colors">Portfolio</a>
        <a href="/blog" class="hover:text-[#1A1A1A] transition-colors">Blog</a>
      </div>
      <a href="#contact" class="hidden md:inline-flex items-center gap-2 px-5 py-2 bg-[#1A1A1A] rounded-full text-sm hover:bg-[#333] transition-all duration-300" style="color:#FFFFFF;">
        Me contacter
      </a>
      <button id="menu-btn" class="md:hidden p-2 text-[#6B6B6B] hover:text-[#1A1A1A]" aria-label="Ouvrir le menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-[#E5E5E5] pt-4">
      <div class="flex flex-col gap-4 text-sm">
        <a href="#about" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">À propos</a>
        <a href="#services" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Services</a>
        <a href="#experience" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Expérience</a>
        <a href="#portfolio" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Portfolio</a>
        <a href="/blog" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Blog</a>
        <a href="#contact" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Contact</a>
      </div>
    </div>
  </nav>

  <main>
  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col px-6 md:px-16 text-[#1A1A1A] overflow-hidden" style="background: radial-gradient(ellipse 80% 80% at 40% 50%, #f0f0ee 0%, #e8e8e6 100%);">

    <div class="max-w-6xl mx-auto w-full relative z-10 flex-1 flex flex-col justify-center pt-20 pb-8">

      <!-- 3D Wireframe Globe (Three.js) -->
      <div id="globe-container" class="absolute top-[10%] right-[-8%] w-[55vw] h-[55vw] md:w-[30vw] md:h-[30vw] max-w-[450px] max-h-[450px] z-0 pointer-events-none" style="opacity:0.18;"></div>
      <div id="hero-content">
        <div class="inline-flex items-center gap-2 mb-10" id="badge">
          <span class="w-2 h-2 rounded-full bg-[#22C55E] animate-pulse"></span>
          <span class="text-[#6B6B6B] font-medium" style="font-family:'DM Sans',sans-serif; font-size:11px; letter-spacing:3px; text-transform:uppercase;">DISPONIBLE POUR PROJETS</span>
        </div>
        <div>
          <h1 class="hero-title text-[#1A1A1A] leading-[0.88]" style="font-family:'Playfair Display',serif; font-size:clamp(3.2rem,12vw,9.5rem); font-weight:900; letter-spacing:-3px;">
            <span class="block">Développeur</span>
            <span class="inline-flex items-end gap-6">
              <span>Frontend</span>
              <span class="hidden md:inline-block text-sm text-[#6B6B6B] leading-relaxed font-normal pb-[0.15em]" id="hero-sub" style="font-family:'DM Sans',sans-serif; max-width:180px; font-size:14px; letter-spacing:0;">
                Créateur d'expériences web qui font la différence
              </span>
            </span>
          </h1>
        </div>
        <p class="md:hidden text-sm text-[#6B6B6B] leading-relaxed mt-6" style="font-family:'DM Sans',sans-serif; max-width:260px;">
          Créateur d'expériences web qui font la différence
        </p>
      </div>
    </div>

    <!-- Info bar at bottom of hero -->
    <div class="border-t border-[#D8D8D8]">
      <div class="max-w-6xl mx-auto w-full flex flex-wrap items-center justify-between py-5 gap-6" id="hero-stats">
        <div class="flex flex-wrap items-center gap-6 md:gap-14">
          <div>
            <div class="mb-1" style="font-family:'DM Sans',sans-serif; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#A0A0A0;">BASÉ À</div>
            <div style="font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500; color:#1A1A1A;">Perpignan, FR</div>
          </div>
          <div class="hidden md:block w-px h-8 bg-[#D8D8D8]"></div>
          <div>
            <div class="mb-1" style="font-family:'DM Sans',sans-serif; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#A0A0A0;">EXPÉRIENCE</div>
            <div style="font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500; color:#1A1A1A;">10+ Ans</div>
          </div>
          <div class="hidden md:block w-px h-8 bg-[#D8D8D8]"></div>
          <div>
            <div class="mb-1" style="font-family:'DM Sans',sans-serif; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#A0A0A0;">PROJETS</div>
            <div style="font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500; color:#1A1A1A;">250+</div>
          </div>
        </div>
        <div class="flex items-center gap-2 text-sm" style="font-family:'DM Sans',sans-serif; color:#A0A0A0;">
          Défiler pour explorer
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
        </div>
      </div>
    </div>
  </section>

  <!-- LOGO TICKER — white bg -->
  <div class="py-7 border-y border-[#E5E5E5] overflow-hidden bg-white">
    <div class="marquee-track items-center" style="will-change:transform; gap:0;">
      {[
        { name: 'React', slug: 'react' },
        { name: 'Next.js', slug: 'nextdotjs' },
        { name: 'WordPress', slug: 'wordpress' },
        { name: 'Tailwind', slug: 'tailwindcss' },
        { name: 'TypeScript', slug: 'typescript' },
        { name: 'Supabase', slug: 'supabase' },
        { name: 'Node.js', slug: 'nodedotjs' },
        { name: 'Vercel', slug: 'vercel' },
        { name: 'Figma', slug: 'figma' },
        { name: 'React', slug: 'react' },
        { name: 'Next.js', slug: 'nextdotjs' },
        { name: 'WordPress', slug: 'wordpress' },
        { name: 'Tailwind', slug: 'tailwindcss' },
        { name: 'TypeScript', slug: 'typescript' },
        { name: 'Supabase', slug: 'supabase' },
        { name: 'Node.js', slug: 'nodedotjs' },
        { name: 'Vercel', slug: 'vercel' },
        { name: 'Figma', slug: 'figma' },
      ].map(tech => (
        <div class="flex items-center gap-3 px-10 whitespace-nowrap border-r border-[#E5E5E5]">
          <img
            src={`https://cdn.simpleicons.org/${tech.slug}/888888`}
            alt={tech.name}
            width="20"
            height="20"
            style="filter: grayscale(1) opacity(0.6);"
            loading="lazy"
            decoding="async"
          />
          <span class="text-[#767676] text-sm font-medium tracking-wide">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- CLIENT LOGO TICKER — white bg, reverse scroll -->
  <div class="py-6 border-b border-[#E5E5E5] overflow-hidden bg-[#FAFAF8]">
    <div class="marquee-track-reverse items-center" style="will-change:transform; gap:0;">
      {[
        { name: 'Apple', logo: 'apple' },
        { name: 'Boulanger', logo: 'boulanger' },
        { name: 'Orange', logo: 'orange' },
        { name: 'Assurance Maladie', logo: 'cpam' },
        { name: 'Malt', logo: 'malt' },
        { name: 'Copernic', logo: 'copernic' },
