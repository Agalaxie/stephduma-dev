---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Stéphane Duma — Développeur Frontend Expert</title>
  <meta name="description" content="Développeur Frontend Expert React, Next.js & WordPress. +10 ans d'expérience, 57 projets livrés. Basé à Perpignan." />
  <meta property="og:title" content="Stéphane Duma — Développeur Frontend Expert" />
  <meta property="og:description" content="Développeur Frontend Expert React, Next.js & WordPress. +10 ans d'expérience, 57 projets livrés." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://stephduma.dev" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,800;0,900;1,400;1,700;1,800;1,900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- NAV — white bg -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-5 px-6 md:px-12" style="background:#f0f0ee;">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="#" class="text-xl font-bold tracking-tight text-[#1A1A1A]" style="font-size:1.5rem; letter-spacing:0.05em;">SD</a>
      <div class="hidden md:flex items-center gap-8 text-sm text-[#6B6B6B]">
        <a href="#about" class="hover:text-[#1A1A1A] transition-colors">À propos</a>
        <a href="#services" class="hover:text-[#1A1A1A] transition-colors">Services</a>
        <a href="#experience" class="hover:text-[#1A1A1A] transition-colors">Expérience</a>
        <a href="#portfolio" class="hover:text-[#1A1A1A] transition-colors">Portfolio</a>
      </div>
      <a href="#contact" class="hidden md:inline-flex items-center gap-2 px-5 py-2 bg-[#1A1A1A] rounded-full text-sm text-white hover:bg-[#333] transition-all duration-300">
        Me contacter
      </a>
      <button id="menu-btn" class="md:hidden p-2 text-[#6B6B6B] hover:text-[#1A1A1A]">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-[#E5E5E5] pt-4">
      <div class="flex flex-col gap-4 text-sm">
        <a href="#about" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">À propos</a>
        <a href="#services" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Services</a>
        <a href="#experience" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Expérience</a>
        <a href="#portfolio" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Portfolio</a>
        <a href="#contact" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Contact</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col px-6 md:px-16 text-[#1A1A1A] overflow-hidden" style="background: radial-gradient(ellipse 80% 80% at 40% 50%, #f0f0ee 0%, #e8e8e6 100%);">

    <div class="max-w-6xl mx-auto w-full relative z-10 flex-1 flex flex-col justify-center pt-20 pb-8">

      <!-- 3D Wireframe Globe (Three.js) -->
      <div id="globe-container" class="absolute top-[15%] right-[-5%] w-[30vw] h-[30vw] max-w-[450px] max-h-[450px] z-0 pointer-events-none" style="opacity:0.28;"></div>
      <div id="hero-content">
        <div class="inline-flex items-center gap-2 mb-10" id="badge">
          <span class="w-2 h-2 rounded-full bg-[#22C55E] animate-pulse"></span>
          <span class="text-[#6B6B6B] font-medium" style="font-family:'DM Sans',sans-serif; font-size:11px; letter-spacing:3px; text-transform:uppercase;">DISPONIBLE POUR PROJETS</span>
        </div>
        <div>
          <h1 class="hero-title text-[#1A1A1A] leading-[0.88]" style="font-family:'Playfair Display',serif; font-size:clamp(5rem,12vw,9.5rem); font-weight:900; letter-spacing:-3px;">
            <span class="block">Développeur</span>
            <span class="inline-flex items-end gap-6">
              <span>Frontend</span>
              <span class="hidden md:inline-block text-sm text-[#6B6B6B] leading-relaxed font-normal pb-[0.15em]" id="hero-sub" style="font-family:'DM Sans',sans-serif; max-width:180px; font-size:14px; letter-spacing:0;">
                Créateur d'expériences web qui font la différence
              </span>
            </span>
          </h1>
        </div>
        <p class="md:hidden text-sm text-[#6B6B6B] leading-relaxed mt-6" style="font-family:'DM Sans',sans-serif; max-width:260px;">
          Créateur d'expériences web qui font la différence
        </p>
      </div>
    </div>

    <!-- Info bar at bottom of hero -->
    <div class="border-t border-[#D8D8D8]">
      <div class="max-w-6xl mx-auto w-full flex flex-wrap items-center justify-between py-5 gap-6" id="hero-stats">
        <div class="flex flex-wrap items-center gap-8 md:gap-14">
          <div>
            <div class="mb-1" style="font-family:'DM Sans',sans-serif; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#A0A0A0;">BASÉ À</div>
            <div style="font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500; color:#1A1A1A;">Perpignan, FR</div>
          </div>
          <div class="w-px h-8 bg-[#D8D8D8]"></div>
          <div>
            <div class="mb-1" style="font-family:'DM Sans',sans-serif; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#A0A0A0;">EXPÉRIENCE</div>
            <div style="font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500; color:#1A1A1A;">10+ Ans</div>
          </div>
          <div class="w-px h-8 bg-[#D8D8D8]"></div>
          <div>
            <div class="mb-1" style="font-family:'DM Sans',sans-serif; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#A0A0A0;">PROJETS</div>
            <div style="font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500; color:#1A1A1A;">57+</div>
          </div>
        </div>
        <div class="flex items-center gap-2 text-sm" style="font-family:'DM Sans',sans-serif; color:#A0A0A0;">
          Scroll to explore
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
        </div>
      </div>
    </div>
  </section>

  <!-- LOGO TICKER — white bg -->
  <div class="py-7 border-y border-[#E5E5E5] overflow-hidden bg-white">
    <div class="marquee-track items-center" style="will-change:transform; gap:0;">
      {[
        { name: 'React', slug: 'react' },
        { name: 'Next.js', slug: 'nextdotjs' },
        { name: 'WordPress', slug: 'wordpress' },
        { name: 'Tailwind', slug: 'tailwindcss' },
        { name: 'TypeScript', slug: 'typescript' },
        { name: 'Supabase', slug: 'supabase' },
        { name: 'Node.js', slug: 'nodedotjs' },
        { name: 'Vercel', slug: 'vercel' },
        { name: 'Figma', slug: 'figma' },
        { name: 'React', slug: 'react' },
        { name: 'Next.js', slug: 'nextdotjs' },
        { name: 'WordPress', slug: 'wordpress' },
        { name: 'Tailwind', slug: 'tailwindcss' },
        { name: 'TypeScript', slug: 'typescript' },
        { name: 'Supabase', slug: 'supabase' },
        { name: 'Node.js', slug: 'nodedotjs' },
        { name: 'Vercel', slug: 'vercel' },
        { name: 'Figma', slug: 'figma' },
      ].map(tech => (
        <div class="flex items-center gap-3 px-10 whitespace-nowrap border-r border-[#E5E5E5]">
          <img
            src={`https://cdn.simpleicons.org/${tech.slug}/888888`}
            alt={tech.name}
            width="20"
            height="20"
            style="filter: grayscale(1) opacity(0.6);"
            loading="lazy"
          />
          <span class="text-[#999] text-sm font-medium tracking-wide">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ABOUT — white bg -->
  <section id="about" class="py-24 px-6 md:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-12">
        <span class="section-label mb-6 inline-block">À propos</span>
      </div>
      <div class="reveal grid md:grid-cols-2 gap-16 items-start">
        <div>
          <h2 class="text-3xl md:text-[3.5rem] font-normal leading-tight tracking-[-1px] text-[#1A1A1A] mb-6" style="line-height:1.15;">
            Le développement web a toujours été plus qu'un métier — c'est ma passion.
          </h2>
        </div>
        <div>
          <p class="text-[#6B6B6B] leading-relaxed mb-10 text-base">
            Je crée des interfaces qui fonctionnent, qui séduisent, et qui convertissent. Avec 10 ans d'expérience en React, Next.js et WordPress, je suis le partenaire technique dont votre projet a besoin.
          </p>
          <div class="grid grid-cols-2 gap-8">
            <div>
              <div class="serif-italic text-[5.5rem] leading-none text-[#1A1A1A]">+57</div>
              <div class="text-sm text-[#6B6B6B] mt-2">Projets livrés</div>
            </div>
            <div>
              <div class="serif-italic text-[5.5rem] leading-none text-[#1A1A1A]">+50</div>
              <div class="text-sm text-[#6B6B6B] mt-2">Clients satisfaits</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES — white bg, 2x2 grid -->
  <section id="services" class="py-24 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Services</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]">Ce que j'apporte</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {[
          {
            title: 'Sites React & Next.js',
            desc: 'Applications web performantes, SSR, SSG, SEO optimisé. Du MVP à la production, avec une architecture solide et maintenable.',
            dark: false
          },
          {
            title: 'Thèmes WordPress',
            desc: 'Thèmes sur mesure, performants et maintenables. WooCommerce, ACF, Gutenberg. Pas de page builders, du vrai code.',
            dark: false
          },
          {
            title: 'Intégrations & APIs',
            desc: 'Connexion de vos outils : Supabase, Stripe, CRMs, outils IA. Je fais parler vos systèmes entre eux.',
            dark: true
          },
          {
            title: 'Performance & Accessibilité',
            desc: 'Audits Core Web Vitals, optimisation images, lazy loading, accessibilité RGAA. Des sites rapides, pour tout le monde.',
            dark: false
          },
        ].map(service => (
          <div class={`reveal rounded-2xl transition-all duration-300 group cursor-default flex flex-col justify-between min-h-[240px] p-8 md:p-10 ${service.dark ? 'bg-[#141414] text-white' : 'border border-[#E5E5E5] bg-white text-[#1A1A1A] hover:border-[#ccc]'}`}>
            <div class="flex items-start justify-between">
              <h3 class="text-xl font-bold">{service.title}</h3>
              <div class={`w-10 h-10 rounded-full border flex items-center justify-center flex-shrink-0 ${service.dark ? 'bg-white/10 border-white/20' : 'border-[#E5E5E5]'}`}>
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class={service.dark ? 'text-white/70' : 'text-[#6B6B6B]'}><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
            <p class={`text-sm leading-relaxed mt-6 ${service.dark ? 'text-gray-400' : 'text-[#6B6B6B]'}`}>{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXPERIENCE — white bg, numbered timeline -->
  <section id="experience" class="py-24 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Expérience</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]">Une décennie de croissance</h2>
      </div>
      <div class="space-y-0">
        {[
          { period: '2014–2018', role: 'Développeur WordPress', desc: 'Création de thèmes et plugins WordPress sur mesure. Clients e-commerce, institutions, startups françaises.' },
          { period: '2018–2022', role: 'Développeur React & Frontend', desc: 'Migration vers React et l\'écosystème JavaScript moderne. Intégrations API, applications SPA complexes, travail en équipe agile.' },
          { period: '2022–Présent', role: 'Développeur Next.js & IA', desc: 'Spécialisation Next.js App Router, Supabase, intégrations IA. Création de SaaS, outils métier et sites ultra-performants.' },
        ].map(exp => (
          <div class="reveal flex items-start justify-between py-12 border-b border-[#E5E5E5] last:border-0 gap-8">
            <div class="flex items-start gap-4 flex-1">
              <div class="w-1.5 h-1.5 rounded-full bg-[#1A1A1A] mt-2.5 flex-shrink-0"></div>
              <div>
                <h3 class="text-lg font-bold mb-1 text-[#1A1A1A]">{exp.role}</h3>
                <p class="text-[#6B6B6B] text-sm leading-relaxed max-w-lg">{exp.desc}</p>
              </div>
            </div>
            <div class="serif-italic text-3xl md:text-5xl text-[#1A1A1A] flex-shrink-0 text-right whitespace-nowrap">{exp.period}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PORTFOLIO — white bg, 3x2 grid -->
  <section id="portfolio" class="py-24 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Portfolio</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]">Projets sélectionnés</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-4">
        {[
          { name: 'DigitalQT', desc: 'SaaS analytics & dashboard', img: '/portfolio-digitalqt.jpg', url: 'https://www.digitalqt.com' },
          { name: 'Cinq Mars', desc: 'Site immobilier prestige', img: '/portfolio-cinqmars.jpg', url: 'https://www.cinqmars.fr' },
          { name: 'Atypic Cactus', desc: 'E-commerce plantes & cactus', img: '/portfolio-cactus.jpg', url: 'https://www.atypic-cactus.com' },
          { name: 'DICASTRI 2026', desc: 'Plateforme institutionnelle', img: '/portfolio-dicastri.jpg', url: 'https://dicastri-2026.vercel.app' },
          { name: 'Dashboard', desc: 'Interface analytics & reporting', img: '/portfolio-dashboard.jpg', url: 'https://dashboard-kappa-six-54.vercel.app' },
        ].map(project => (
          <a href={project.url} target="_blank" rel="noopener" class="reveal group relative overflow-hidden rounded-2xl border border-[#E5E5E5] hover:border-[#bbb] hover:shadow-lg transition-all duration-400 cursor-pointer block">
            <div class="aspect-[4/3] overflow-hidden bg-gray-100">
              <img
                src={project.img}
                alt={project.name}
                class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105"
                style="filter: grayscale(20%);"
                loading="lazy"
              />
            </div>
            <div class="p-5 flex items-start justify-between">
              <div>
                <h3 class="font-semibold text-[#1A1A1A] mb-1">{project.name}</h3>
                <p class="text-[#6B6B6B] text-sm">{project.desc}</p>
              </div>
              <div class="w-8 h-8 rounded-full border border-[#E5E5E5] flex items-center justify-center flex-shrink-0 group-hover:bg-[#1A1A1A] group-hover:border-[#1A1A1A] transition-all duration-300 mt-0.5">
                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-[#1A1A1A] group-hover:text-white transition-colors duration-300"><path d="M7 17L17 7M7 7h10v10"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL — #F7F7F7 bg -->
  <section class="py-24 px-6 md:px-12 bg-[#F7F7F7]">
    <div class="max-w-4xl mx-auto">
      <div class="reveal text-center">
        <div class="text-6xl text-[#ccc] mb-6 serif-italic">"</div>
        <blockquote class="text-2xl md:text-3xl font-normal leading-relaxed text-[#1A1A1A] mb-8">
          Stéphane a transformé notre site en quelques semaines. Résultat au-delà de nos attentes.
        </blockquote>
        <div class="flex items-center justify-center gap-4">
          <div class="w-10 h-10 rounded-full bg-[#E5E5E5] flex items-center justify-center text-sm font-bold text-[#1A1A1A]">JM</div>
          <div class="text-left">
            <div class="text-sm font-medium text-[#1A1A1A]">Jean-Marc</div>
            <div class="text-xs text-[#6B6B6B]">Dirigeant, PME</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA — dark bg #141414 -->
  <section id="contact" class="py-32 px-6 md:px-12 bg-[#141414]">
    <div class="max-w-4xl mx-auto">
      <div class="reveal text-center">
        <span class="section-label--dark mb-8 inline-block" style="display:inline-flex; border:1px solid #333; border-radius:100px; padding:6px 16px; font-size:11px; font-weight:500; letter-spacing:3px; text-transform:uppercase;">Contact</span>
        <h2 class="text-5xl md:text-[6rem] font-normal mb-8 leading-none tracking-[-2px] text-white" style="font-family:'Playfair Display',serif; font-weight:700;">
          Travaillons<br/>ensemble
        </h2>
        <p class="text-gray-400 mb-10 max-w-md mx-auto">
          Un projet en tête ? Parlons-en. Je réponds sous 24h.
        </p>
        <a
          href="mailto:me@stephduma.dev"
          class="inline-flex items-center gap-3 px-8 py-4 bg-white text-[#141414] font-medium rounded-full hover:bg-gray-200 transition-all duration-300 hover:gap-5 group"
        >
          me@stephduma.dev
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="group-hover:rotate-45 transition-transform duration-300"><path d="M7 17L17 7M7 7h10v10"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER — dark #141414 -->
  <footer class="py-12 px-6 md:px-12 bg-[#141414] border-t border-[#333]">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-sm text-gray-500">
        Stéphane Duma &copy; 2026 &middot; Tous droits réservés
      </div>
      <div class="flex items-center gap-6 text-sm text-gray-500">
        <a href="https://github.com/Agalaxie" target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>
        <a href="https://malt.fr" target="_blank" rel="noopener" class="hover:text-white transition-colors">Malt</a>
        <a href="https://linkedin.com" target="_blank" rel="noopener" class="hover:text-white transition-colors">LinkedIn</a>
      </div>
    </div>
  </footer>

  <!-- Custom cursor -->
  <div id="cursor-ring" style="position:fixed; top:0; left:0; width:40px; height:40px; border:1.5px solid rgba(23,23,23,0.5); border-radius:50%; pointer-events:none; z-index:9999; transform:translate(-50%,-50%); transition: width 0.3s ease, height 0.3s ease, border-color 0.3s ease, opacity 0.3s ease;"></div>
  <div id="cursor-dot" style="position:fixed; top:0; left:0; width:8px; height:8px; background:rgb(23,23,23); border-radius:50%; pointer-events:none; z-index:10000; transform:translate(-50%,-50%);"></div>

</body>
</html>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Navbar scroll — add shadow on scroll
  const navbar = document.getElementById('navbar');
  ScrollTrigger.create({
    start: 'top -80',
    onUpdate: (self) => {
      if (self.progress > 0) {
        navbar?.classList.add('shadow-sm', 'py-3');
        navbar?.classList.remove('py-5');
        (navbar as HTMLElement).style.background = '#ffffff';
      } else {
        navbar?.classList.remove('shadow-sm', 'py-3');
        navbar?.classList.add('py-5');
        (navbar as HTMLElement).style.background = '#f0f0ee';
      }
    }
  });

  // Hero entrance animation
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  tl.from('#badge', { y: 20, opacity: 0, duration: 0.6 })
    .from('.hero-title > span', { y: '100%', opacity: 0, duration: 0.8, stagger: 0.1 }, '-=0.2')
    .from('#hero-sub', { y: 30, opacity: 0, duration: 0.7 }, '-=0.4')
    .from('#hero-stats', { y: 20, opacity: 0, duration: 0.5 }, '-=0.3');

  // Scroll reveal
  gsap.utils.toArray('.reveal').forEach((el: any) => {
    gsap.from(el, {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        once: true,
      }
    });
  });

  // Mobile menu
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => mobileMenu?.classList.add('hidden'));
  });

  // Custom cursor
  const cursorRing = document.getElementById('cursor-ring');
  const cursorDot = document.getElementById('cursor-dot');
  let mouseX = 0, mouseY = 0;
  let ringX = 0, ringY = 0;

  if (window.matchMedia('(pointer: fine)').matches && cursorRing && cursorDot) {
    document.body.style.cursor = 'none';
    document.querySelectorAll('a, button').forEach(el => {
      (el as HTMLElement).style.cursor = 'none';
    });

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      cursorDot.style.left = mouseX + 'px';
      cursorDot.style.top = mouseY + 'px';
    });

    const animateCursor = () => {
      ringX += (mouseX - ringX) * 0.12;
      ringY += (mouseY - ringY) * 0.12;
      cursorRing.style.left = ringX + 'px';
      cursorRing.style.top = ringY + 'px';
      requestAnimationFrame(animateCursor);
    };
    animateCursor();

    document.querySelectorAll('a, button').forEach(el => {
      el.addEventListener('mouseenter', () => {
        cursorRing.style.width = '55px';
        cursorRing.style.height = '55px';
        cursorRing.style.opacity = '0.5';
      });
      el.addEventListener('mouseleave', () => {
        cursorRing.style.width = '40px';
        cursorRing.style.height = '40px';
        cursorRing.style.opacity = '1';
      });
    });
  } else {
    cursorRing?.remove();
    cursorDot?.remove();
  }

  // Three.js wireframe globe
  import * as THREE from 'three';

  const globeContainer = document.getElementById('globe-container');
  if (globeContainer) {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 1000);
    camera.position.z = 4;

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setSize(450, 450);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    globeContainer.appendChild(renderer.domElement);

    const material = new THREE.MeshBasicMaterial({
      color: 0x555555,
      wireframe: true,
      transparent: true,
      opacity: 0.6,
    });

    // Main sphere
    const geometry = new THREE.IcosahedronGeometry(1.5, 4);
    const sphere = new THREE.Mesh(geometry, material);
    scene.add(sphere);

    // Second sphere rotated for more geodesic lines
    const material2 = new THREE.MeshBasicMaterial({
      color: 0x888888,
      wireframe: true,
      transparent: true,
      opacity: 0.25,
    });
    const geometry2 = new THREE.IcosahedronGeometry(1.52, 2);
    const sphere2 = new THREE.Mesh(geometry2, material2);
    sphere2.rotation.x = Math.PI / 4;
    sphere2.rotation.z = Math.PI / 6;
    scene.add(sphere2);

    let targetRotX = 0;
    let targetRotY = 0;

    const heroSection = globeContainer.closest('section');
    heroSection?.addEventListener('mousemove', (e) => {
      const rect = heroSection.getBoundingClientRect();
      targetRotY = ((e.clientX - rect.left) / rect.width - 0.5) * 1.5;
      targetRotX = ((e.clientY - rect.top) / rect.height - 0.5) * -1;
    });

    const animate = () => {
      requestAnimationFrame(animate);
      sphere.rotation.y += (targetRotY - sphere.rotation.y) * 0.02 + 0.002;
      sphere.rotation.x += (targetRotX - sphere.rotation.x) * 0.02;
      sphere2.rotation.y += (targetRotY - sphere2.rotation.y) * 0.015 + 0.001;
      sphere2.rotation.x += (targetRotX - sphere2.rotation.x) * 0.015;
      renderer.render(scene, camera);
    };
    animate();
  }
</script>
