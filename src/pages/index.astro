---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Stéphane Duma — Développeur Frontend Expert</title>
  <meta name="description" content="Développeur Frontend Expert React, Next.js & WordPress. +10 ans d'expérience, 57 projets livrés. Basé à Perpignan." />
  <meta property="og:title" content="Stéphane Duma — Développeur Frontend Expert" />
  <meta property="og:description" content="Développeur Frontend Expert React, Next.js & WordPress. +10 ans d'expérience, 57 projets livrés." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://stephduma.dev" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- NAV — white bg -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-white transition-all duration-300 py-5 px-6 md:px-12">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="#" class="text-xl font-bold tracking-tight text-[#1A1A1A]" style="font-size:1.5rem; letter-spacing:0.05em;">SD</a>
      <div class="hidden md:flex items-center gap-8 text-sm text-[#6B6B6B]">
        <a href="#about" class="hover:text-[#1A1A1A] transition-colors">À propos</a>
        <a href="#services" class="hover:text-[#1A1A1A] transition-colors">Services</a>
        <a href="#experience" class="hover:text-[#1A1A1A] transition-colors">Expérience</a>
        <a href="#portfolio" class="hover:text-[#1A1A1A] transition-colors">Portfolio</a>
      </div>
      <a href="#contact" class="hidden md:inline-flex items-center gap-2 px-5 py-2 border border-[#1A1A1A] rounded-full text-sm text-[#1A1A1A] hover:bg-[#1A1A1A] hover:text-white transition-all duration-300">
        Me contacter
      </a>
      <button id="menu-btn" class="md:hidden p-2 text-[#6B6B6B] hover:text-[#1A1A1A]">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-[#E5E5E5] pt-4">
      <div class="flex flex-col gap-4 text-sm">
        <a href="#about" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">À propos</a>
        <a href="#services" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Services</a>
        <a href="#experience" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Expérience</a>
        <a href="#portfolio" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Portfolio</a>
        <a href="#contact" class="text-[#6B6B6B] hover:text-[#1A1A1A] transition-colors">Contact</a>
      </div>
    </div>
  </nav>

  <!-- HERO — light bg, dark text, serif font -->
  <section class="relative min-h-screen flex flex-col px-6 md:px-12 bg-[#F7F7F5] text-[#1A1A1A] overflow-hidden">
    <!-- Wireframe globe SVG -->
    <div class="absolute right-[-2%] top-[10%] w-[420px] h-[420px] opacity-[0.12] pointer-events-none select-none hidden md:block">
      <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="200" cy="200" r="180" stroke="#1A1A1A" stroke-width="0.8"/>
        <ellipse cx="200" cy="200" rx="90" ry="180" stroke="#1A1A1A" stroke-width="0.8"/>
        <ellipse cx="200" cy="200" rx="150" ry="180" stroke="#1A1A1A" stroke-width="0.8"/>
        <ellipse cx="200" cy="200" rx="180" ry="70" stroke="#1A1A1A" stroke-width="0.8"/>
        <ellipse cx="200" cy="200" rx="180" ry="130" stroke="#1A1A1A" stroke-width="0.8"/>
        <line x1="20" y1="200" x2="380" y2="200" stroke="#1A1A1A" stroke-width="0.8"/>
        <line x1="200" y1="20" x2="200" y2="380" stroke="#1A1A1A" stroke-width="0.8"/>
      </svg>
    </div>
    <div class="max-w-6xl mx-auto w-full relative z-10 flex-1 flex flex-col justify-center pt-24 pb-8">
      <div id="hero-content">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 text-xs text-[#6B6B6B] mb-10" id="badge">
          <span class="w-2 h-2 rounded-full bg-[#22C55E] animate-pulse"></span>
          <span class="uppercase tracking-widest font-medium" style="font-size:11px; letter-spacing:3px;">DISPONIBLE POUR PROJETS</span>
        </div>
        <div class="flex flex-wrap items-end gap-x-8 gap-y-0">
          <h1 class="hero-title leading-[0.9] tracking-[-3px] text-[#1A1A1A]" style="font-family:'DM Serif Display',serif; font-size:clamp(5rem,13vw,10rem); font-weight:400;">
            <span class="block">Développeur</span>
            <span class="block">Frontend</span>
          </h1>
          <p class="text-base text-[#6B6B6B] max-w-[200px] leading-relaxed mb-4 self-end" id="hero-sub">
            Créateur d'expériences web qui font la différence
          </p>
        </div>
      </div>
    </div>
    <!-- Info bar at bottom of hero -->
    <div class="border-t border-[#E5E5E5] mt-auto">
      <div class="max-w-6xl mx-auto w-full flex flex-wrap items-center justify-between py-6 px-6 md:px-0 gap-6" id="hero-stats">
        <div class="flex flex-wrap items-center gap-8 md:gap-12">
          <div>
            <div class="text-[10px] uppercase tracking-widest text-[#A0A0A0] mb-1">Basé à</div>
            <div class="text-sm text-[#1A1A1A] font-medium">Perpignan, FR</div>
          </div>
          <div class="w-px h-8 bg-[#E5E5E5]"></div>
          <div>
            <div class="text-[10px] uppercase tracking-widest text-[#A0A0A0] mb-1">Expérience</div>
            <div class="text-sm text-[#1A1A1A] font-medium">10+ Ans</div>
          </div>
          <div class="w-px h-8 bg-[#E5E5E5]"></div>
          <div>
            <div class="text-[10px] uppercase tracking-widest text-[#A0A0A0] mb-1">Projets</div>
            <div class="text-sm text-[#1A1A1A] font-medium">57 Projets</div>
          </div>
        </div>
        <div class="flex items-center gap-2 text-[#A0A0A0] text-sm">
          Scroll to explore
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
        </div>
      </div>
    </div>
  </section>

  <!-- LOGO TICKER — white bg -->
  <div class="py-8 border-y border-[#E5E5E5] overflow-hidden bg-white">
    <div class="marquee-track gap-12 items-center" style="will-change:transform;">
      {['React', 'Next.js', 'WordPress', 'Tailwind', 'TypeScript', 'Supabase', 'Node.js', 'Vercel', 'GSAP', 'Figma', 'React', 'Next.js', 'WordPress', 'Tailwind', 'TypeScript', 'Supabase', 'Node.js', 'Vercel', 'GSAP', 'Figma'].map(tech => (
        <span class="text-[#6B6B6B] font-medium text-sm whitespace-nowrap px-6 uppercase tracking-widest">{tech}</span>
      ))}
    </div>
  </div>

  <!-- ABOUT — white bg -->
  <section id="about" class="py-24 px-6 md:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-12">
        <span class="section-label mb-6 inline-block">À propos</span>
      </div>
      <div class="reveal grid md:grid-cols-2 gap-16 items-start">
        <div>
          <h2 class="text-3xl md:text-[3.5rem] font-normal leading-tight tracking-[-1px] text-[#1A1A1A] mb-6" style="line-height:1.15;">
            Le développement web a toujours été plus qu'un métier — c'est ma passion.
          </h2>
        </div>
        <div>
          <p class="text-[#6B6B6B] leading-relaxed mb-10 text-base">
            Je crée des interfaces qui fonctionnent, qui séduisent, et qui convertissent. Avec 10 ans d'expérience en React, Next.js et WordPress, je suis le partenaire technique dont votre projet a besoin.
          </p>
          <div class="grid grid-cols-2 gap-8">
            <div>
              <div class="serif-italic text-[5.5rem] leading-none text-[#1A1A1A]">+57</div>
              <div class="text-sm text-[#6B6B6B] mt-2">Projets livrés</div>
            </div>
            <div>
              <div class="serif-italic text-[5.5rem] leading-none text-[#1A1A1A]">+50</div>
              <div class="text-sm text-[#6B6B6B] mt-2">Clients satisfaits</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES — white bg, 2x2 grid -->
  <section id="services" class="py-24 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Services</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]">Ce que j'apporte</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {[
          {
            title: 'Sites React & Next.js',
            desc: 'Applications web performantes, SSR, SSG, SEO optimisé. Du MVP à la production, avec une architecture solide et maintenable.',
            dark: false
          },
          {
            title: 'Thèmes WordPress',
            desc: 'Thèmes sur mesure, performants et maintenables. WooCommerce, ACF, Gutenberg. Pas de page builders, du vrai code.',
            dark: false
          },
          {
            title: 'Intégrations & APIs',
            desc: 'Connexion de vos outils : Supabase, Stripe, CRMs, outils IA. Je fais parler vos systèmes entre eux.',
            dark: true
          },
          {
            title: 'Performance & Accessibilité',
            desc: 'Audits Core Web Vitals, optimisation images, lazy loading, accessibilité RGAA. Des sites rapides, pour tout le monde.',
            dark: false
          },
        ].map(service => (
          <div class={`reveal p-8 md:p-10 rounded-2xl transition-all duration-300 group cursor-default relative ${service.dark ? 'bg-[#232323] text-white' : 'border border-[#E5E5E5] bg-white text-[#1A1A1A] hover:border-[#ccc]'}`}>
            <div class={`absolute top-8 right-8 w-10 h-10 rounded-full border flex items-center justify-center ${service.dark ? 'border-white/20' : 'border-[#E5E5E5]'}`}>
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class={service.dark ? 'text-white/60' : 'text-[#6B6B6B]'}><path d="M7 17L17 7M7 7h10v10"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3 pr-12">{service.title}</h3>
            <p class={`text-sm leading-relaxed ${service.dark ? 'text-gray-400' : 'text-[#6B6B6B]'}`}>{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXPERIENCE — white bg, numbered timeline -->
  <section id="experience" class="py-24 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Expérience</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]">Une décennie de croissance</h2>
      </div>
      <div class="space-y-0">
        {[
          { num: '01', period: '2014–2018', role: 'Développeur WordPress', desc: 'Création de thèmes et plugins WordPress sur mesure. Clients e-commerce, institutions, startups françaises.' },
          { num: '02', period: '2018–2022', role: 'Développeur React & Frontend', desc: 'Migration vers React et l\'écosystème JavaScript moderne. Intégrations API, applications SPA complexes, travail en équipe agile.' },
          { num: '03', period: '2022–Présent', role: 'Développeur Next.js & IA', desc: 'Spécialisation Next.js App Router, Supabase, intégrations IA. Création de SaaS, outils métier et sites ultra-performants.' },
        ].map(exp => (
          <div class="reveal flex gap-6 md:gap-12 py-12 border-b border-[#E5E5E5] last:border-0 items-start">
            <div class="flex-shrink-0 text-[#6B6B6B] text-sm font-medium pt-1">{exp.num}</div>
            <div class="flex-1 grid md:grid-cols-[200px_1fr] gap-4 items-start">
              <div>
                <div class="serif-italic text-4xl md:text-5xl text-[#1A1A1A]">{exp.period}</div>
              </div>
              <div>
                <h3 class="text-xl font-bold mb-2 text-[#1A1A1A]">{exp.role}</h3>
                <p class="text-[#6B6B6B] text-sm leading-relaxed">{exp.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PORTFOLIO — white bg, 3x2 grid -->
  <section id="portfolio" class="py-24 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span class="section-label mb-6 inline-block">Portfolio</span>
        <h2 class="text-4xl md:text-[3.75rem] font-normal tracking-[-1px] text-[#1A1A1A]">Projets sélectionnés</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-4">
        {[
          { name: 'DigitalQT', desc: 'SaaS dashboard clients' },
          { name: 'Cinq Mars', desc: 'Site immobilier prestige' },
          { name: 'Cactus Shop', desc: 'E-commerce plantes' },
          { name: 'DQT Dashboard', desc: 'Interface analytics' },
          { name: 'DICASTRI 2026', desc: 'Plateforme institutionnelle' },
          { name: 'i2t', desc: 'App traduction IA' },
        ].map(project => (
          <div class="reveal group relative overflow-hidden rounded-2xl border border-[#E5E5E5] hover:border-[#ccc] transition-all duration-300 cursor-pointer">
            <div class="aspect-[4/3] bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center p-8" style="filter:grayscale(100%);">
              <span class="text-3xl font-bold text-[#1A1A1A]/10 group-hover:text-[#1A1A1A]/20 transition-all duration-500">{project.name}</span>
            </div>
            <div class="p-5">
              <h3 class="font-bold text-[#1A1A1A] mb-1">{project.name}</h3>
              <p class="text-[#6B6B6B] text-sm">{project.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL — #F7F7F7 bg -->
  <section class="py-24 px-6 md:px-12 bg-[#F7F7F7]">
    <div class="max-w-4xl mx-auto">
      <div class="reveal text-center">
        <div class="text-6xl text-[#ccc] mb-6 serif-italic">"</div>
        <blockquote class="text-2xl md:text-3xl font-normal leading-relaxed text-[#1A1A1A] mb-8">
          Stéphane a transformé notre site en quelques semaines. Résultat au-delà de nos attentes.
        </blockquote>
        <div class="flex items-center justify-center gap-4">
          <div class="w-10 h-10 rounded-full bg-[#E5E5E5] flex items-center justify-center text-sm font-bold text-[#1A1A1A]">JM</div>
          <div class="text-left">
            <div class="text-sm font-medium text-[#1A1A1A]">Jean-Marc</div>
            <div class="text-xs text-[#6B6B6B]">Dirigeant, PME</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA — light bg like PDF -->
  <section id="contact" class="py-32 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-4xl mx-auto">
      <div class="reveal text-center">
        <span class="section-label mb-8 inline-block">Contact</span>
        <h2 class="text-5xl md:text-[6rem] font-normal mb-8 leading-none tracking-[-2px] text-[#1A1A1A]" style="font-family:'DM Serif Display',serif;">
          Travaillons<br/>ensemble
        </h2>
        <p class="text-[#6B6B6B] mb-10 max-w-md mx-auto">
          Un projet en tête ? Parlons-en. Je réponds sous 24h.
        </p>
        <a
          href="mailto:me@stephduma.dev"
          class="inline-flex items-center gap-3 px-8 py-4 bg-[#1A1A1A] text-white font-medium rounded-full hover:bg-[#333] transition-all duration-300 hover:gap-5 group"
        >
          me@stephduma.dev
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="group-hover:rotate-45 transition-transform duration-300"><path d="M7 17L17 7M7 7h10v10"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER — dark #141414 -->
  <footer class="py-12 px-6 md:px-12 bg-white border-t border-[#E5E5E5]">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-sm text-gray-500">
        Stéphane Duma &copy; 2026 &middot; Tous droits réservés
      </div>
      <div class="flex items-center gap-6 text-sm text-gray-500">
        <a href="https://github.com/Agalaxie" target="_blank" rel="noopener" class="hover:text-[#1A1A1A] transition-colors">GitHub</a>
        <a href="https://malt.fr" target="_blank" rel="noopener" class="hover:text-[#1A1A1A] transition-colors">Malt</a>
        <a href="https://linkedin.com" target="_blank" rel="noopener" class="hover:text-[#1A1A1A] transition-colors">LinkedIn</a>
      </div>
    </div>
  </footer>

</body>
</html>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Navbar scroll — add shadow on scroll
  const navbar = document.getElementById('navbar');
  ScrollTrigger.create({
    start: 'top -80',
    onUpdate: (self) => {
      if (self.progress > 0) {
        navbar?.classList.add('shadow-sm', 'py-3');
        navbar?.classList.remove('py-5');
      } else {
        navbar?.classList.remove('shadow-sm', 'py-3');
        navbar?.classList.add('py-5');
      }
    }
  });

  // Hero entrance animation
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  tl.from('#badge', { y: 20, opacity: 0, duration: 0.6 })
    .from('.hero-title span', { y: '100%', opacity: 0, duration: 0.8, stagger: 0.1 }, '-=0.2')
    .from('#hero-sub', { y: 30, opacity: 0, duration: 0.7 }, '-=0.4')
    .from('#hero-stats', { y: 20, opacity: 0, duration: 0.5 }, '-=0.3');

  // Scroll reveal
  gsap.utils.toArray('.reveal').forEach((el: any) => {
    gsap.from(el, {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        once: true,
      }
    });
  });

  // Mobile menu
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => mobileMenu?.classList.add('hidden'));
  });
</script>
