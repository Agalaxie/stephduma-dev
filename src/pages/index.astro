                <span class={`block h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-[#1A1A1A] w-6' : 'bg-[#ccc] w-2'}`}></span>
              </button>
            ))}
          </div>
          <button id="next-testimonial" class="w-10 h-10 rounded-full border border-[#E5E5E5] flex items-center justify-center hover:bg-[#1A1A1A] hover:border-[#1A1A1A] hover:text-white transition-all duration-300 text-[#1A1A1A]" aria-label="Suivant">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA — dark bg #141414 -->
  <section id="contact" class="py-32 px-6 md:px-12 bg-[#141414]">
    <div class="max-w-4xl mx-auto">
      <div class="reveal text-center">
        <span class="section-label--dark mb-8 inline-block" style="display:inline-flex; border:1px solid #333; border-radius:100px; padding:6px 16px; font-size:11px; font-weight:500; letter-spacing:3px; text-transform:uppercase;">Contact</span>
        <h2 class="text-5xl md:text-[6rem] font-normal mb-8 leading-none tracking-[-2px] text-white" style="font-family:'Playfair Display',serif; font-weight:700;">
          Travaillons<br/>ensemble
        </h2>
        <p class="text-gray-400 mb-10 max-w-md mx-auto">
          Un projet en tête ? Parlons-en. Je réponds sous 24h.
        </p>
        <a
          href="mailto:me@stephduma.dev"
          class="inline-flex items-center gap-3 px-8 py-4 bg-white text-[#141414] font-medium rounded-full hover:bg-gray-200 transition-all duration-300 hover:gap-5 group"
        >
          me@stephduma.dev
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="group-hover:rotate-45 transition-transform duration-300"><path d="M7 17L17 7M7 7h10v10"/></svg>
        </a>
      </div>
    </div>
  </section>

  </main>
  <!-- FOOTER — dark #141414 -->
  <footer class="py-12 px-6 md:px-12 bg-[#141414] border-t border-[#333]">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-sm" style="color:#9CA3AF;">
        Stéphane Duma &copy; 2026 &middot; Tous droits réservés
      </div>
      <div class="flex items-center gap-6 text-sm" style="color:#9CA3AF;">
        <a href="https://github.com/Agalaxie" target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>
        <a href="https://www.malt.fr/profile/stephanedumas" target="_blank" rel="noopener" class="hover:text-white transition-colors">Malt</a>
        <a href="https://linkedin.com" target="_blank" rel="noopener" class="hover:text-white transition-colors">LinkedIn</a>
        <a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a>
      </div>
    </div>
  </footer>

  <!-- Custom cursor -->
  <div id="cursor-ring" style="position:fixed; top:0; left:0; width:40px; height:40px; border:1.5px solid rgba(23,23,23,0.5); border-radius:50%; pointer-events:none; z-index:9999; transform:translate(-50%,-50%); transition: width 0.3s ease, height 0.3s ease, border-color 0.3s ease, opacity 0.3s ease;"></div>
  <div id="cursor-dot" style="position:fixed; top:0; left:0; width:8px; height:8px; background:rgba(23,23,23,0.5); border-radius:50%; pointer-events:none; z-index:10000; transform:translate(-50%,-50%);"></div>

</body>
</html>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Navbar scroll — add shadow on scroll
  const navbar = document.getElementById('navbar');
  ScrollTrigger.create({
    start: 'top -80',
    onUpdate: (self) => {
      if (self.progress > 0) {
        navbar?.classList.add('shadow-sm', 'py-3');
        navbar?.classList.remove('py-5');
        (navbar as HTMLElement).style.background = '#ffffff';
      } else {
        navbar?.classList.remove('shadow-sm', 'py-3');
        navbar?.classList.add('py-5');
        (navbar as HTMLElement).style.background = '#f0f0ee';
      }
    }
  });

  // Hero entrance animation
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  tl.from('#badge', { y: 20, opacity: 0, duration: 0.6 })
    .from('.hero-title > span', { y: '100%', opacity: 0, duration: 0.8, stagger: 0.1 }, '-=0.2')
    .from('#hero-sub', { y: 30, opacity: 0, duration: 0.7 }, '-=0.4')
    .from('#hero-stats', { y: 20, opacity: 0, duration: 0.5 }, '-=0.3');

  // Scroll reveal
  gsap.utils.toArray('.reveal').forEach((el: any) => {
    gsap.from(el, {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        once: true,
      }
    });
  });

  // Mobile menu
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => mobileMenu?.classList.add('hidden'));
  });

  // Custom cursor
  const cursorRing = document.getElementById('cursor-ring');
  const cursorDot = document.getElementById('cursor-dot');
  let mouseX = 0, mouseY = 0;
  let ringX = 0, ringY = 0;

  if (window.matchMedia('(pointer: fine)').matches && cursorRing && cursorDot) {
    document.body.style.cursor = 'none';
    document.querySelectorAll('a, button').forEach(el => {
      (el as HTMLElement).style.cursor = 'none';
    });

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      cursorDot.style.left = mouseX + 'px';
      cursorDot.style.top = mouseY + 'px';
    });

    const animateCursor = () => {
      ringX += (mouseX - ringX) * 0.12;
      ringY += (mouseY - ringY) * 0.12;
      cursorRing.style.left = ringX + 'px';
      cursorRing.style.top = ringY + 'px';
      requestAnimationFrame(animateCursor);
    };
    animateCursor();

    document.querySelectorAll('a, button').forEach(el => {
      el.addEventListener('mouseenter', () => {
        cursorRing.style.width = '55px';
        cursorRing.style.height = '55px';
        cursorRing.style.opacity = '0.5';
      });
      el.addEventListener('mouseleave', () => {
        cursorRing.style.width = '40px';
        cursorRing.style.height = '40px';
        cursorRing.style.opacity = '1';
      });
    });
  } else {
    cursorRing?.remove();
    cursorDot?.remove();
  }

  // Three.js wireframe globe — lazy loaded
  const globeContainer = document.getElementById('globe-container');
  if (globeContainer) {
    import('three').then((THREE) => {
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 1000);
      camera.position.z = 4;

      const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
      renderer.setSize(450, 450);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
      globeContainer.appendChild(renderer.domElement);

      const material = new THREE.MeshBasicMaterial({
        color: 0x555555,
        wireframe: true,
        transparent: true,
        opacity: 0.6,
      });

      const geometry = new THREE.IcosahedronGeometry(1.5, 4);
      const sphere = new THREE.Mesh(geometry, material);
      scene.add(sphere);

      const material2 = new THREE.MeshBasicMaterial({
        color: 0x888888,
        wireframe: true,
        transparent: true,
        opacity: 0.25,
      });
      const geometry2 = new THREE.IcosahedronGeometry(1.52, 2);
      const sphere2 = new THREE.Mesh(geometry2, material2);
      sphere2.rotation.x = Math.PI / 4;
      sphere2.rotation.z = Math.PI / 6;
      scene.add(sphere2);

      let targetRotX = 0;
      let targetRotY = 0;

      const heroSection = globeContainer.closest('section');
      heroSection?.addEventListener('mousemove', (e) => {
        const rect = heroSection.getBoundingClientRect();
        targetRotY = ((e.clientX - rect.left) / rect.width - 0.5) * 1.5;
        targetRotX = ((e.clientY - rect.top) / rect.height - 0.5) * -1;
      });

      const animate = () => {
        requestAnimationFrame(animate);
        sphere.rotation.y += (targetRotY - sphere.rotation.y) * 0.02 + 0.002;
        sphere.rotation.x += (targetRotX - sphere.rotation.x) * 0.02;
        sphere2.rotation.y += (targetRotY - sphere2.rotation.y) * 0.015 + 0.001;
        sphere2.rotation.x += (targetRotX - sphere2.rotation.x) * 0.015;
        renderer.render(scene, camera);
      };
      animate();
    });
  }

  // Testimonial slider
  const slides = document.querySelectorAll('.testimonial-slide');
  const dots = document.querySelectorAll('.testimonial-dot');
  let currentSlide = 0;
  const totalSlides = slides.length;

  function showSlide(index: number) {
    slides.forEach((s, i) => {
      (s as HTMLElement).classList.toggle('hidden', i !== index);
    });
    dots.forEach((d, i) => {
      const span = d.querySelector('span')!;
      span.classList.toggle('bg-[#1A1A1A]', i === index);
      span.classList.toggle('w-6', i === index);
      span.classList.toggle('bg-[#ccc]', i !== index);
      span.classList.toggle('w-2', i !== index);
    });
    currentSlide = index;
  }

  document.getElementById('next-testimonial')?.addEventListener('click', () => {
    showSlide((currentSlide + 1) % totalSlides);
  });
  document.getElementById('prev-testimonial')?.addEventListener('click', () => {
    showSlide((currentSlide - 1 + totalSlides) % totalSlides);
  });
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      showSlide(Number((dot as HTMLElement).dataset.index));
    });
  });

  // Auto-advance every 6s
  setInterval(() => showSlide((currentSlide + 1) % totalSlides), 6000);
</script>
